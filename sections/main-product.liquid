                        {% endcapture %}
                        {% assign companion_markup = companion_markup | append: bundle_item_markup %}
                      {% endunless %}
                    {% endif %}
                  {% endfor %}
                {% endif %}

                {% if rendered_companion_count > 0 %}
                  <div class="nv-product__block nv-product__block--fbt" {{ block.shopify_attributes }}>
                    <div
                      class="nv-product__fbt{% if block.settings.show_plus_signs %} nv-product__fbt--show-plus{% endif %}"
                      data-fbt
                      data-money-format="{{ shop.money_format | escape }}"
                      data-currency-code="{{ cart.currency.iso_code | default: shop.currency }}"
                      style="--nv-product-fbt-image-size: {{ block.settings.fbt_card_size }}px; --nv-product-fbt-image-height: {{ block.settings.fbt_card_image_height }}px; --nv-product-fbt-title-size: {{ block.settings.fbt_title_font_size }}px; --nv-product-fbt-title-clamp: {{ block.settings.fbt_title_line_clamp }}; --nv-product-fbt-price-size: {{ block.settings.price_font_size }}px; --nv-product-fbt-total-size: {{ block.settings.total_font_size }}px; --nv-product-fbt-compare-size: {{ block.settings.fbt_compare_price_font_size }}px; --nv-product-fbt-meta-size: {{ block.settings.fbt_meta_font_size }}px; --nv-product-fbt-pad-top: {{ block.settings.section_padding_top }}px; --nv-product-fbt-pad-bottom: {{ block.settings.section_padding_bottom }}px; --nv-product-fbt-card-radius: {{ block.settings.fbt_card_radius }}px; --nv-product-fbt-card-gap: {{ block.settings.fbt_card_gap }}px; --nv-product-fbt-card-pad: {{ block.settings.fbt_card_padding }}px; --nv-product-fbt-button-size: {{ block.settings.fbt_cta_font_size }}px; --nv-product-fbt-button-height: {{ block.settings.fbt_cta_height }}px; --nv-product-fbt-button-bg: {{ block.settings.fbt_cta_bg_color }}; --nv-product-fbt-button-text: {{ block.settings.fbt_cta_text_color }}; --nv-product-fbt-container-radius: {{ block.settings.fbt_container_radius }}px; --nv-product-fbt-container-padding: {{ block.settings.fbt_container_padding }}px; --nv-product-fbt-container-max: {{ block.settings.fbt_container_max_width }}px; --nv-product-fbt-summary-width: {{ block.settings.fbt_summary_width }}px; --nv-product-fbt-summary-radius: {{ block.settings.fbt_summary_radius }}px; --nv-product-fbt-summary-padding: {{ block.settings.fbt_summary_padding }}px; --nv-product-fbt-summary-bg: {{ block.settings.fbt_summary_background }}; --nv-product-fbt-summary-border: {{ block.settings.fbt_summary_border_color }}; --nv-product-fbt-bg: {{ block.settings.fbt_background_color }}; --nv-product-fbt-border: {{ block.settings.fbt_border_color }}; --nv-product-fbt-check-size: {{ block.settings.fbt_check_size }}px; --nv-product-fbt-image-pad: {{ block.settings.fbt_image_padding }}px; --nv-product-fbt-plus-size: {{ block.settings.fbt_plus_sign_size }}px; --nv-product-fbt-heading-size: {{ block.settings.fbt_heading_font_size }}px;"
                    >
                      {% if block.settings.heading != blank %}
