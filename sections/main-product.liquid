                    <p class="nv-product__meta-line"><span class="nv-product__meta-label">{{ block.settings.label }}</span><span class="nv-product__meta-value" data-current-sku>{{ current_variant.sku }}</span></p>
                  </div>
                {% endif %}

              {% when 'type' %}
                {% if product.type != blank %}
                  <div class="nv-product__block nv-product__block--type" {{ block.shopify_attributes }}>
                    <p class="nv-product__meta-line"><span class="nv-product__meta-label">{{ block.settings.label }}</span><span class="nv-product__meta-value">{{ product.type }}</span></p>
                  </div>
                {% endif %}

              {% when 'barcode' %}
