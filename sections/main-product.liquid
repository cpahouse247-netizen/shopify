                {% if block.settings.label != blank and block.settings.value != blank %}
                  <div class="nv-product__block nv-product__block--field" {{ block.shopify_attributes }}>
                    <p class="nv-product__meta-line"><span class="nv-product__meta-label">{{ block.settings.label }}</span><span class="nv-product__meta-value">{{ block.settings.value }}</span></p>
                  </div>
                {% endif %}

              {% when 'collapsible_tab' %}
                {% if block.settings.content != blank %}
                  <div class="nv-product__block nv-product__block--collapsible" {{ block.shopify_attributes }}>
                    <details class="nv-product__accordion-item" {% if block.settings.open_by_default %}open{% endif %}>
                      <summary>{{ block.settings.heading }}</summary>
                      <div class="rte nv-product__accordion-content">{{ block.settings.content }}</div>
                    </details>
                  </div>
                {% endif %}

              {% when 'pop_up_text' %}
                {% if block.settings.content != blank %}
                  <div class="nv-product__block nv-product__block--popup" {{ block.shopify_attributes }}>
                    <button type="button" class="nv-product__popup-trigger" data-nv-dialog-trigger="nv-popup-{{ section.id }}-{{ block.id }}">
                      {{ block.settings.link_label }}
                    </button>
                    <dialog class="nv-product__popup" id="nv-popup-{{ section.id }}-{{ block.id }}">
                      <div class="nv-product__popup-inner">
                        <div class="nv-product__popup-head">
                          <h3>{{ block.settings.heading }}</h3>
                          <button type="button" class="nv-product__popup-close" data-nv-dialog-close aria-label="Close">×</button>
                        </div>
                        <div class="rte nv-product__popup-body">{{ block.settings.content }}</div>
                      </div>
                    </dialog>
                  </div>
                {% endif %}

              {% when 'pop_up_contact_form' %}
                <div class="nv-product__block nv-product__block--popup" {{ block.shopify_attributes }}>
                  <button type="button" class="nv-product__popup-trigger" data-nv-dialog-trigger="nv-contact-popup-{{ section.id }}-{{ block.id }}">
                    {{ block.settings.link_label }}
                  </button>
                  <dialog class="nv-product__popup" id="nv-contact-popup-{{ section.id }}-{{ block.id }}">
                    <div class="nv-product__popup-inner">
                      <div class="nv-product__popup-head">
                        <h3>{{ block.settings.heading }}</h3>
                        <button type="button" class="nv-product__popup-close" data-nv-dialog-close aria-label="Close">×</button>
                      </div>
                      {% if block.settings.body != blank %}
                        <div class="rte nv-product__popup-body">{{ block.settings.body }}</div>
                      {% endif %}
                      {% form 'contact', class: 'nv-product__contact-form' %}
                        <input type="hidden" name="contact[context]" value="Product page: {{ product.title | escape }}">
                        <div class="nv-product__contact-grid">
                          <input type="text" name="contact[name]" placeholder="Name" required>
                          <input type="email" name="contact[email]" placeholder="Email" required>
                          <textarea name="contact[body]" rows="5" placeholder="How can we help?" required></textarea>
                        </div>
                        <button type="submit" class="btn">{{ block.settings.button_label }}</button>
                      {% endform %}
                    </div>
                  </dialog>
                </div>

              {% when 'share' %}
                <div class="nv-product__block nv-product__block--share" {{ block.shopify_attributes }}>
                  <div
                    class="nv-product__share"
                    style="--nv-product-share-size: {{ block.settings.share_font_size }}px; --nv-product-share-icon-size: {{ block.settings.share_icon_size }}px; --nv-product-share-color: {{ block.settings.share_link_color }}; --nv-product-share-hover: {{ block.settings.share_link_hover_color }}; --nv-product-share-gap: {{ block.settings.share_item_gap }}px; --nv-product-share-pad-top: {{ block.settings.share_block_padding_top }}px; --nv-product-share-pad-bottom: {{ block.settings.share_block_padding_bottom }}px; --nv-product-share-divider: {{ block.settings.share_divider_color }};"
                  >
                    {% if block.settings.show_share_heading and block.settings.share_heading_text != blank %}
                      <p class="meta-label">{{ block.settings.share_heading_text }}</p>
                    {% endif %}
                    <div class="nv-product__share-links" role="list" aria-label="Share product">
                      <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_param_escape }}" target="_blank" rel="noopener" role="listitem">
                        <span class="nv-product__share-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 8h2.4V4.8H14c-2.2 0-3.8 1.6-3.8 3.9V11H8v3.2h2.2V20h3.4v-5.8h2.6l.5-3.2h-3.1V9.1c0-.7.4-1.1 1.1-1.1Z"></path>
                          </svg>
                        </span>
                        <span>Facebook</span>
                      </a>
                      <a href="https://twitter.com/intent/tweet?url={{ share_url | url_param_escape }}&text={{ share_title | url_param_escape }}" target="_blank" rel="noopener" role="listitem">
                        <span class="nv-product__share-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 5 19 19"></path>
                            <path d="M19 5 5 19"></path>
                          </svg>
                        </span>
                        <span>X / Twitter</span>
                      </a>
                      <a href="https://pinterest.com/pin/create/button/?url={{ share_url | url_param_escape }}&description={{ share_title | url_param_escape }}" target="_blank" rel="noopener" role="listitem">
                        <span class="nv-product__share-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9.2 19.3c.9-1.5 1.5-3.1 1.9-5"></path>
                            <path d="M10.4 13.3c.8.7 1.8 1.1 2.9 1.1 2.9 0 4.8-2.2 4.8-5 0-3.1-2.5-5.4-6-5.4-4.2 0-6.6 2.9-6.6 6 0 1.4.5 2.7 1.7 3.2"></path>
                          </svg>
                        </span>
                        <span>Pin it</span>
                      </a>
                      <a href="mailto:?subject={{ share_title | url_param_escape }}&body={{ share_url | url_param_escape }}" role="listitem">
                        <span class="nv-product__share-icon" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 5v10"></path>
                            <path d="M8.5 8.5 12 5l3.5 3.5"></path>
                            <path d="M5 19h14"></path>
                          </svg>
                        </span>
                        <span>Share more</span>
                      </a>
                    </div>
                  </div>
                </div>

              {% when 'custom_liquid' %}
                {% if block.settings.custom_liquid != blank %}
                  <div class="nv-product__block nv-product__block--custom-liquid" {{ block.shopify_attributes }}>
                    {{ block.settings.custom_liquid }}
                  </div>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div> 
  </div>
</section>

<script>
  (function() {
    const sectionRoot = document.getElementById('MainProduct-{{ section.id }}');
    const gallery = document.getElementById('nvMediaGallery-{{ section.id }}');
    const featuredImage = document.getElementById('nvFeaturedImage-{{ section.id }}');
    const featuredFrame = gallery ? gallery.querySelector('.nv-media-gallery__item') : null;
    const thumbTrack = gallery ? gallery.querySelector('[data-media-thumbs]') : null;
    const navPrev = gallery ? gallery.querySelector('[data-media-nav="prev"]') : null;
    const navNext = gallery ? gallery.querySelector('[data-media-nav="next"]') : null;

    if (gallery && featuredImage && featuredFrame) {
      const thumbs = Array.from(gallery.querySelectorAll('[data-media-thumb]'));
      let activeIndex = thumbs.findIndex((thumb) => thumb.classList.contains('is-active'));
      if (activeIndex < 0) activeIndex = 0;

      const activateThumb = (index) => {
        const thumb = thumbs[index];
        if (!thumb) return;
        const src = thumb.getAttribute('data-media-src');
        const alt = thumb.getAttribute('data-media-alt');
        if (src) featuredImage.src = src;
        if (alt) featuredImage.alt = alt;

        thumbs.forEach((item) => item.classList.remove('is-active'));
        thumb.classList.add('is-active');
        activeIndex = index;

        if (thumbTrack) {
          thumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      };

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => activateThumb(index));
      });

      if (navPrev) {
        navPrev.addEventListener('click', () => {
          const nextIndex = activeIndex <= 0 ? thumbs.length - 1 : activeIndex - 1;
          activateThumb(nextIndex);
        });
      }

      if (navNext) {
        navNext.addEventListener('click', () => {
          const nextIndex = activeIndex >= thumbs.length - 1 ? 0 : activeIndex + 1;
          activateThumb(nextIndex);
        });
      }

      if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
        const setOrigin = (event) => {
          const rect = featuredFrame.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          featuredFrame.style.setProperty('--nv-featured-origin-x', `${Math.max(0, Math.min(100, x))}%`);
          featuredFrame.style.setProperty('--nv-featured-origin-y', `${Math.max(0, Math.min(100, y))}%`);
        };

        featuredFrame.addEventListener('mouseenter', setOrigin);
        featuredFrame.addEventListener('mousemove', setOrigin);
        featuredFrame.addEventListener('mouseleave', () => {
          featuredFrame.style.setProperty('--nv-featured-origin-x', '50%');
          featuredFrame.style.setProperty('--nv-featured-origin-y', '50%');
        });
      }

      if (thumbs.length > 0) activateThumb(activeIndex);
    }

    if (sectionRoot) {
      const reviewsSlot = sectionRoot.querySelector('[data-nv-reviews-slot]');
      if (reviewsSlot) {
        const appBlocks = Array.from(sectionRoot.querySelectorAll('[data-nv-product-app-block]'));
        const reviewAppBlock = appBlocks.find((node) => {
          return !node.querySelector('[data-nv-buy-with-prime-slot], .nv-bwp-slot, [data-buy-with-prime-button-id]');
        });

        if (reviewAppBlock) {
          reviewsSlot.hidden = false;
          reviewsSlot.appendChild(reviewAppBlock);
          reviewAppBlock.classList.add('nv-product__block--reviews-app');
        }
      }

      const reviewsAnchor = sectionRoot.querySelector('[data-nv-reviews-anchor]');
      if (reviewsAnchor) {
        reviewsAnchor.addEventListener('click', () => {
          const target = sectionRoot.querySelector('.nv-product__block--reviews-app, [data-nv-product-app-block]');
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      }

      const variantSelect = sectionRoot.querySelector('#ProductVariant-{{ section.id }}');
      const syncShopPayVariant = () => {
        if (!variantSelect) return;
        sectionRoot.querySelectorAll('[data-shop-pay-variant]').forEach((input) => {
          input.value = variantSelect.value;
        });
      };
      const syncVariantMeta = () => {
        if (!variantSelect) return;
        const selectedOption = variantSelect.selectedOptions[0];
        const selectedSku = selectedOption ? (selectedOption.dataset.variantSku || '').trim() : '';
        const selectedBarcode = selectedOption ? (selectedOption.dataset.variantBarcode || '').trim() : '';
        const selectedPrice = selectedOption ? Number(selectedOption.dataset.variantPrice || 0) : 0;
        const selectedCompare = selectedOption ? Number(selectedOption.dataset.variantCompare || 0) : 0;
        const selectedUnit = selectedOption ? (selectedOption.dataset.variantUnit || '').trim() : '';

        sectionRoot.querySelectorAll('[data-current-sku]').forEach((element) => {
          element.textContent = selectedSku;
        });
        sectionRoot.querySelectorAll('[data-meta-field="sku"]').forEach((element) => {
          element.hidden = selectedSku === '';
        });

        sectionRoot.querySelectorAll('[data-current-barcode]').forEach((element) => {
          element.textContent = selectedBarcode;
        });
        sectionRoot.querySelectorAll('[data-meta-field="barcode"]').forEach((element) => {
          element.hidden = selectedBarcode === '';
        });

        sectionRoot.querySelectorAll('.nv-product__block--meta-row').forEach((block) => {
          const visibleItems = Array.from(block.querySelectorAll('.nv-product__meta-row-item')).filter((item) => !item.hidden);
          block.hidden = visibleItems.length === 0;
        });

        sectionRoot.querySelectorAll('[data-current-product="true"]').forEach((item) => {
          item.dataset.price = selectedPrice;
          item.dataset.compare = selectedCompare;
          const priceElement = item.querySelector('[data-fbt-item-price]');
          const compareElement = item.querySelector('[data-fbt-item-compare]');
          const unitElement = item.querySelector('[data-fbt-item-unit]');
          if (priceElement) priceElement.textContent = formatMoney(selectedPrice);
          if (compareElement) {
            if (selectedCompare > selectedPrice) {
              compareElement.textContent = formatMoney(selectedCompare);
              compareElement.hidden = false;
            } else {
              compareElement.hidden = true;
            }
          }
          if (unitElement) {
            const fallbackUnit = (unitElement.dataset.defaultText || '').trim();
            const resolvedUnit = selectedUnit || fallbackUnit;
            unitElement.textContent = resolvedUnit;
            unitElement.hidden = resolvedUnit === '';
          }
        });

        updateFbtState();
      };
      const syncShopPayQuantity = (value) => {
        sectionRoot.querySelectorAll('[data-shop-pay-quantity]').forEach((input) => {
          input.value = Math.max(1, Number(value) || 1);
        });
        updateFbtState();
      };

      const formatMoney = (cents) => {
        const bundleRoot = sectionRoot.querySelector('[data-fbt]');
        const fallbackFormat = bundleRoot ? bundleRoot.dataset.moneyFormat : '';
        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          return window.Shopify.formatMoney(cents, fallbackFormat || undefined);
        }

        const currencyCode = bundleRoot ? (bundleRoot.dataset.currencyCode || 'USD') : 'USD';
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: currencyCode }).format((Number(cents) || 0) / 100);
      };

      const getActivePageQuantity = () => {
        const quantityInput = sectionRoot.querySelector('.nv-product__quantity-input');
        return Math.max(1, Number(quantityInput ? quantityInput.value : 1) || 1);
      };

      const getFbtVariantId = (item) => {
        if (!item) return null;
        if (item.dataset.currentProduct === 'true') {
          return variantSelect ? variantSelect.value : '{{ current_variant.id }}';
        }
        const variantSelectInput = item.querySelector('[data-fbt-variant-select]');
        if (variantSelectInput) return variantSelectInput.value;
        const hiddenVariantInput = item.querySelector('[data-fbt-variant-id]');
        return hiddenVariantInput ? hiddenVariantInput.value : null;
      };

      const updateFbtItemFromVariant = (item) => {
        const itemVariantSelect = item.querySelector('[data-fbt-variant-select]');
        if (!itemVariantSelect) return;
        const option = itemVariantSelect.selectedOptions[0];
        const price = option ? Number(option.dataset.price || 0) : 0;
        const compare = option ? Number(option.dataset.compare || 0) : 0;
        const unitText = option ? (option.dataset.unitText || '').trim() : '';
        item.dataset.price = price;
        item.dataset.compare = compare;

        const priceElement = item.querySelector('[data-fbt-item-price]');
        const compareElement = item.querySelector('[data-fbt-item-compare]');
        const unitElement = item.querySelector('[data-fbt-item-unit]');
        if (priceElement) priceElement.textContent = formatMoney(price);
        if (compareElement) {
          if (compare > price) {
            compareElement.textContent = formatMoney(compare);
            compareElement.hidden = false;
          } else {
            compareElement.hidden = true;
          }
        }
        if (unitElement) {
          const fallbackUnit = (unitElement.dataset.defaultText || '').trim();
          const resolvedUnit = unitText || fallbackUnit;
          unitElement.textContent = resolvedUnit;
          unitElement.hidden = resolvedUnit === '';
        }
      };

      const updateFbtState = () => {
        const fbtRoot = sectionRoot.querySelector('[data-fbt]');
        if (!fbtRoot) return;
        let total = 0;
        let compareTotal = 0;
        let checkedCount = 0;

        const renderedItems = Array.from(fbtRoot.querySelectorAll('.nv-product__fbt-items [data-fbt-item]')).filter((item) => !item.hidden);

        renderedItems.forEach((item) => {
          const checkbox = item.querySelector('[data-fbt-check]');
          const isChecked = checkbox ? checkbox.checked : false;
          item.classList.toggle('is-unchecked', !isChecked);
          if (!isChecked) return;

          const quantity = item.dataset.currentProduct === 'true' ? getActivePageQuantity() : 1;
          const price = Number(item.dataset.price || 0);
          const compare = Number(item.dataset.compare || 0);
          total += price * quantity;
          if (compare > price) compareTotal += compare * quantity;
          checkedCount += 1;
        });

        const compareElement = fbtRoot.querySelector('[data-fbt-total-compare]');
        const totalPriceElement = fbtRoot.querySelector('[data-fbt-total-price]');
        const addButton = fbtRoot.querySelector('[data-fbt-add]');
        const buttonText = fbtRoot.querySelector('[data-fbt-button-text]');
        const buttonLabel = addButton ? (addButton.dataset.fbtButtonLabel || 'Add all') : 'Add all';
        if (totalPriceElement) {
          totalPriceElement.textContent = formatMoney(total);
        }
        if (buttonText) {
          buttonText.textContent = checkedCount > 0 ? `${buttonLabel} ${checkedCount} to cart` : buttonLabel;
        }
        if (compareElement) {
          if (compareTotal > total) {
            compareElement.textContent = `Was ${formatMoney(compareTotal)}`;
            compareElement.hidden = false;
          } else {
            compareElement.hidden = true;
          }
        }
        if (addButton) addButton.disabled = checkedCount === 0;
      };

      if (variantSelect) {
        variantSelect.addEventListener('change', syncShopPayVariant);
        variantSelect.addEventListener('change', syncVariantMeta);
        syncShopPayVariant();
        syncVariantMeta();
      }

      const markBwpLoading = (container) => {
        let foundLoadingLabel = false;
        container.querySelectorAll('*').forEach((element) => {
          const text = element.textContent ? element.textContent.replace(/\s+/g, ' ').trim() : '';
          const isLeaf = element.children.length === 0;
          const isLoadingLabel = isLeaf && text === 'Loading Buy with Prime';
          element.classList.toggle('nv-bwp-app-loading-label', isLoadingLabel);
          if (isLoadingLabel) foundLoadingLabel = true;
        });
        container.classList.toggle('is-bwp-loading', foundLoadingLabel);
      };

      sectionRoot.querySelectorAll('.nv-product__block--app').forEach((block) => {
        markBwpLoading(block);
        const observer = new MutationObserver(() => markBwpLoading(block));
        observer.observe(block, { childList: true, subtree: true, characterData: true });
      });

      sectionRoot.querySelectorAll('[data-qty-control]').forEach((control) => {
        const input = control.querySelector('.nv-product__quantity-input');
        if (!input) return;

        control.querySelectorAll('[data-qty-change]').forEach((button) => {
          button.addEventListener('click', () => {
            const delta = Number(button.getAttribute('data-qty-change')) || 0;
            const current = Number(input.value) || 1;
            input.value = Math.max(1, current + delta);
            syncShopPayQuantity(input.value);
            input.dispatchEvent(new Event('change', { bubbles: true }));
          });
        });

        input.addEventListener('input', () => syncShopPayQuantity(input.value));
        input.addEventListener('change', () => syncShopPayQuantity(input.value));
      });

      const firstQuantityInput = sectionRoot.querySelector('.nv-product__quantity-input');
      if (firstQuantityInput) syncShopPayQuantity(firstQuantityInput.value);

      sectionRoot.querySelectorAll('[data-fbt-item]').forEach((item) => {
        updateFbtItemFromVariant(item);
        const checkbox = item.querySelector('[data-fbt-check]');
        if (checkbox) checkbox.addEventListener('change', updateFbtState);

        const itemVariantSelect = item.querySelector('[data-fbt-variant-select]');
        if (itemVariantSelect) {
          itemVariantSelect.addEventListener('change', () => {
            updateFbtItemFromVariant(item);
            updateFbtState();
          });
        }
      });

      const fbtAddButton = sectionRoot.querySelector('[data-fbt-add]');
      if (fbtAddButton) {
        fbtAddButton.addEventListener('click', async () => {
          const fbtRoot = sectionRoot.querySelector('[data-fbt]');
          const messageElement = fbtRoot ? fbtRoot.querySelector('[data-fbt-message]') : null;
          const items = [];

          sectionRoot.querySelectorAll('[data-fbt-item]').forEach((item) => {
            const checkbox = item.querySelector('[data-fbt-check]');
            if (!checkbox || !checkbox.checked) return;
            const variantId = getFbtVariantId(item);
            if (!variantId) return;
            items.push({
              id: Number(variantId),
              quantity: item.dataset.currentProduct === 'true' ? getActivePageQuantity() : 1
            });
          });

          if (items.length === 0) {
            if (messageElement) {
              messageElement.hidden = false;
              messageElement.textContent = 'Select at least one item to add this bundle.';
            }
            return;
          }

          fbtAddButton.disabled = true;
          if (messageElement) {
            messageElement.hidden = true;
            messageElement.textContent = '';
          }

          try {
            const response = await fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({ items })
            });

            if (!response.ok) throw new Error('Unable to add selected items.');
            await response.json();

            if (messageElement) {
              messageElement.hidden = false;
              messageElement.textContent = 'Selected items were added to cart.';
            }
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            window.dispatchEvent(new CustomEvent('cart:refresh'));
          } catch (error) {
            if (messageElement) {
              messageElement.hidden = false;
              messageElement.textContent = 'We could not add the selected items. Please try again.';
            }
          } finally {
            updateFbtState();
          }
        });
      }

      updateFbtState();
    }

    if (!sectionRoot || !window.HTMLDialogElement) return;

    sectionRoot.querySelectorAll('[data-nv-dialog-trigger]').forEach((trigger) => {
      const dialog = sectionRoot.querySelector(`#${trigger.getAttribute('data-nv-dialog-trigger')}`);
      if (!dialog) return;

      trigger.addEventListener('click', () => dialog.showModal());
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
      });

      dialog.querySelectorAll('[data-nv-dialog-close]').forEach((button) => {
        button.addEventListener('click', () => dialog.close());
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "paragraph",
      "content": "Block-based PDP foundation with app-block support and a premium gallery + info layout.",
    },
    {
      "type": "select",
      "id": "conversion_mode_override",
      "label": "Section conversion mode override",
      "default": "",
      "options": [
        { "value": "", "label": "Use product/theme defaults" },
        { "value": "amazon_attribution", "label": "Amazon attribution" },
        { "value": "buy_with_prime", "label": "Buy with Prime" },
        { "value": "hybrid", "label": "Hybrid" }
      ]
    },
    {
      "type": "textarea",
      "id": "summary",
      "label": "Default summary fallback",
      "default": "A concise product overview that supports the main purchase decision."
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "range",
      "id": "breadcrumb_font_size",
      "label": "Breadcrumb font size",
      "min": 12,
      "max": 16,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "breadcrumb_color",
      "label": "Breadcrumb color",
      "default": "#6B6F6A"
    },
    {
      "type": "color",
      "id": "breadcrumb_active_color",
      "label": "Breadcrumb active color",
      "default": "#1F3A2F"
    },
    {
      "type": "range",
      "id": "breadcrumb_spacing_bottom",
      "label": "Breadcrumb spacing bottom",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 1100,
      "max": 1480,
      "step": 20,
      "default": 1280,
      "unit": "px"
    },
    {
      "type": "range",
