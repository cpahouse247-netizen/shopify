                              <span class="nv-product__fbt-check-indicator" aria-hidden="true">✓</span>
                            </span>
                            <span class="nv-product__fbt-media">
                              {% if bundle_product.featured_media.preview_image %}
                                {{ bundle_product.featured_media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', alt: bundle_product.title }}
                              {% endif %}
                            </span>
                            <span class="nv-product__fbt-copy{% unless block.settings.show_fbt_product_titles %} nv-product__fbt-copy--titles-hidden{% endunless %}">
                              <span class="nv-product__fbt-title{% unless block.settings.show_fbt_product_titles %} nv-product__fbt-title--sr-only{% endunless %}">{{ bundle_title }}</span>
                              {% if block.settings.show_variant_selectors and bundle_product.has_only_default_variant == false %}
                                <select class="nv-product__fbt-variant" data-fbt-variant-select aria-label="Choose {{ bundle_product.title | escape }} option">
                                  {% for bundle_variant_option in bundle_product.variants %}
                                    {% liquid
                                      assign bundle_variant_unit_text = ''
                                      if bundle_variant_option.unit_price_measurement and bundle_variant_option.unit_price != blank
                                        capture bundle_variant_unit_text
                                          echo bundle_variant_option.unit_price | money
                                          echo ' / '
                                          if bundle_variant_option.unit_price_measurement.reference_value != 1
                                            echo bundle_variant_option.unit_price_measurement.reference_value
                                          endif
                                          echo bundle_variant_option.unit_price_measurement.reference_unit
                                        endcapture
                                        assign bundle_variant_unit_text = bundle_variant_unit_text | strip
                                      endif
                                    %}
                                    <option value="{{ bundle_variant_option.id }}" data-price="{{ bundle_variant_option.price }}" data-compare="{{ bundle_variant_option.compare_at_price | default: 0 }}" data-unit-text="{{ bundle_variant_unit_text | escape }}" {% unless bundle_variant_option.available %}disabled{% endunless %}>
                                      {{ bundle_variant_option.title }}{% unless bundle_variant_option.available %} - Sold out{% endunless %}
                                    </option>
                                  {% endfor %}
                                </select>
                              {% else %}
                                <input type="hidden" value="{{ bundle_variant.id }}" data-fbt-variant-id>
                              {% endif %}
                              <span class="nv-product__fbt-price-row">
                                <span class="nv-product__fbt-price" data-fbt-item-price>{{ bundle_variant.price | money }}</span>
                                {% if block.settings.show_compare_price %}
                                  {% if bundle_variant.compare_at_price > bundle_variant.price %}
                                    <span class="nv-product__fbt-compare" data-fbt-item-compare>{{ bundle_variant.compare_at_price | money }}</span>
                                  {% else %}
                                    <span class="nv-product__fbt-compare" data-fbt-item-compare hidden></span>
                                  {% endif %}
                                {% endif %}
                              </span>
                              {% if block.settings.show_unit_text %}
                                <span class="nv-product__fbt-unit-text" data-fbt-item-unit data-default-text="{{ bundle_unit_text | escape }}" {% if bundle_unit_text == blank %}hidden{% endif %}>{{ bundle_unit_text }}</span>
                              {% endif %}
                              {% if block.settings.show_support_text and bundle_support_text != blank %}
                                <span class="nv-product__fbt-support">{{ bundle_support_text }}</span>
                              {% endif %}
