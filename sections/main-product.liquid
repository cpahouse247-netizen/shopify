{% comment %}Main product block-based foundation{% endcomment %}
{%- liquid
  assign resolved_summary = section.settings.summary
  if resolved_summary == blank and product.metafields.custom.short_benefit_summary != blank
    assign resolved_summary = product.metafields.custom.short_benefit_summary.value | default: product.metafields.custom.short_benefit_summary
  endif
  if resolved_summary == blank
    assign resolved_summary = product.description | strip_html | truncatewords: 28
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'nv-product-form-' | append: section.id
  assign shop_pay_form_id = 'nv-shop-pay-form-' | append: section.id
  assign featured_media = current_variant.featured_media | default: product.featured_media | default: product.media.first
  assign variant_picker_blocks = section.blocks | where: 'type', 'variant_picker'
  assign buy_box_chip_blocks = section.blocks | where: 'type', 'buy_box_chip'
  assign quantity_blocks = section.blocks | where: 'type', 'quantity_selector'
  assign buy_button_blocks = section.blocks | where: 'type', 'buy_buttons'
  assign has_variant_picker_block = false
  if variant_picker_blocks.size > 0
    assign has_variant_picker_block = true
  endif
  assign has_quantity_selector_block = false
  if quantity_blocks.size > 0
    assign has_quantity_selector_block = true
  endif
  assign has_buy_buttons_block = false
  if buy_button_blocks.size > 0
    assign has_buy_buttons_block = true
  endif
  assign quantity_block_label = 'Quantity'
  if has_quantity_selector_block
    assign quantity_block_label = quantity_blocks.first.settings.label | default: 'Quantity'
  endif

  assign product_rating_value = 0
  assign product_rating_count = blank
  if product.metafields.reviews.rating.value != blank
    assign rating_object = product.metafields.reviews.rating.value
    assign product_rating_value = rating_object.rating | default: rating_object
  elsif product.metafields.custom.rating != blank
    assign product_rating_value = product.metafields.custom.rating.value | default: product.metafields.custom.rating
  endif
  if product.metafields.reviews.rating_count.value != blank
    assign product_rating_count = product.metafields.reviews.rating_count.value
  elsif product.metafields.reviews.rating_count != blank
    assign product_rating_count = product.metafields.reviews.rating_count
  endif

  assign share_url = shop.url | append: product.url
  assign share_title = product.title

-%}

<section
  id="MainProduct-{{ section.id }}"
  class="section nv-product nv-product--base nv-product--thumbs-{{ section.settings.thumbnail_position }}"
  style="
    --nv-product-max-width: {{ section.settings.content_max_width }}px;
    --nv-product-pad-top: {{ section.settings.section_padding_top }}px;
    --nv-product-pad-bottom: {{ section.settings.section_padding_bottom }}px;
    --nv-product-breadcrumb-size: {{ section.settings.breadcrumb_font_size }}px;
    --nv-product-breadcrumb-color: {{ section.settings.breadcrumb_color }};
    --nv-product-breadcrumb-active: {{ section.settings.breadcrumb_active_color }};
    --nv-product-breadcrumb-bottom: {{ section.settings.breadcrumb_spacing_bottom }}px;
    --nv-product-buybox-gap: {{ section.settings.buy_box_spacing }}px;
    --nv-product-title-size: {{ section.settings.title_font_size }}px;
    --nv-product-summary-size: {{ section.settings.summary_font_size }}px;
    --nv-product-price-size: {{ section.settings.price_font_size }}px;
    --nv-product-rating-size: {{ section.settings.rating_font_size }}px;
    --nv-product-compare-price-size: {{ section.settings.compare_price_font_size }}px;
    --nv-product-price-color: {{ section.settings.price_color }};
    --nv-product-compare-price-color: {{ section.settings.compare_price_color }};
    --nv-product-price-weight: {{ section.settings.price_font_weight }};
    --nv-product-meta-size: {{ section.settings.meta_font_size }}px;
    --nv-product-meta-label-color: {{ section.settings.meta_label_color }};
    --nv-product-meta-value-color: {{ section.settings.meta_value_color }};
    --nv-product-meta-divider-color: {{ section.settings.meta_divider_color }};
    --nv-product-meta-row-pad-top: {{ section.settings.meta_row_padding_top }}px;
    --nv-product-meta-row-pad-bottom: {{ section.settings.meta_row_padding_bottom }}px;
    --nv-product-button-size: {{ section.settings.button_font_size }}px;
    --nv-product-qty-height: {{ section.settings.quantity_control_height }}px;
    --nv-product-qty-radius: {{ section.settings.quantity_control_radius }}px;
    --nv-product-qty-font-size: {{ section.settings.quantity_font_size }}px;
    --nv-product-qty-button-width: {{ section.settings.quantity_button_width }}px;
    --nv-product-buybox-max: {{ section.settings.buy_box_max_width }}px;
    --nv-product-gallery-max: {{ section.settings.gallery_max_width }}px;
    --nv-product-gallery-col: {{ section.settings.gallery_column_width_desktop }}fr;
    --nv-product-details-col: {{ section.settings.details_column_width_desktop }}fr;
    --nv-product-top-gap: {{ section.settings.top_pdp_gap }}px;
    --nv-product-media-radius: {{ section.settings.gallery_border_radius }}px;
    --nv-product-media-gap: {{ section.settings.gallery_gap }}px;
    --nv-product-media-pad: {{ section.settings.media_padding }}px;
    --nv-product-media-frame-pad: {{ section.settings.media_frame_padding }}px;
    --nv-product-gallery-height-desktop: {{ section.settings.gallery_height_desktop }}px;
    --nv-product-gallery-height-mobile: {{ section.settings.gallery_height_mobile }}px;
    --nv-product-thumb-rail-height: {{ section.settings.gallery_height_desktop }}px;
    --nv-product-gallery-bg: {{ section.settings.gallery_background_color }};
    --nv-product-gallery-border: {{ section.settings.media_border_color }};
    --nv-product-thumb-size: {{ section.settings.thumbnail_size }}px;
    --nv-product-thumb-gap: {{ section.settings.thumbnail_gap }}px;
    --nv-product-thumb-radius: {{ section.settings.thumbnail_radius }}px;
    --nv-product-gallery-control-size: {{ section.settings.gallery_control_size }}px;
    --nv-product-reviews-gap: {{ section.settings.reviews_spacing_below_title }}px;
    --nv-product-reviews-gap-bottom: {{ section.settings.reviews_spacing_above_price }}px;
    --nv-product-image-fit: {{ section.settings.image_fit_mode }};
  "
>
  <div class="container container--wide nv-product__container">
    {% if section.settings.show_breadcrumbs %}
      {% render 'nv-breadcrumbs', product: product, collection: collection, show_collections_label: true %}
    {% endif %}

    <div class="nv-product__grid">
      <div class="nv-product__media">
        <div class="nv-media-gallery nv-media-gallery--reference nv-media-gallery--frame-{{ section.settings.gallery_frame_mode }} nv-media-gallery--ratio-{{ section.settings.gallery_aspect_ratio }} surface-panel" id="nvMediaGallery-{{ section.id }}">
          <div class="nv-media-gallery__featured">
            <div class="nv-media-gallery__item">
              {% if product.media.size > 0 %}
                {% if featured_media.preview_image %}
                  <img
                    id="nvFeaturedImage-{{ section.id }}"
                    src="{{ featured_media.preview_image | image_url: width: 1400 }}"
                    alt="{{ featured_media.alt | default: product.title | escape }}"
                    loading="eager"
                    width="{{ featured_media.preview_image.width }}"
                    height="{{ featured_media.preview_image.height }}"
                  >
                {% else %}
                  <img
                    id="nvFeaturedImage-{{ section.id }}"
                    src="{{ 'hero_square.jpeg' | asset_url }}"
                    alt="{{ product.title | escape }}"
                    loading="eager"
                    width="800"
                    height="800"
                  >
                {% endif %}
              {% else %}
                <img
                  id="nvFeaturedImage-{{ section.id }}"
                  src="{{ 'hero_square.jpeg' | asset_url }}"
                  alt="{{ product.title | escape }}"
                  loading="eager"
                  width="800"
                  height="800"
                >
              {% endif %}
            </div>
          </div>

          {% if section.settings.show_thumbnails and product.media.size > 1 %}
            <div class="nv-media-gallery__thumbs-shell" aria-label="Product media thumbnails">
              {% if section.settings.show_prev_next_controls %}
                <button type="button" class="nv-media-gallery__nav nv-media-gallery__nav--prev" data-media-nav="prev" aria-label="Previous image">
                  <span aria-hidden="true">‹</span>
                </button>
              {% endif %}
              <div class="nv-media-gallery__thumbs" data-media-thumbs>
                {% for media in product.media %}
                  <button
                    type="button"
                    class="nv-media-gallery__thumb {% if media.id == featured_media.id %}is-active{% endif %}"
                    data-media-thumb
                    data-media-index="{{ forloop.index0 }}"
                    data-media-src="{{ media.preview_image | image_url: width: 1400 }}"
                    data-media-alt="{{ media.alt | default: product.title | escape }}"
                    aria-label="Show {{ product.title | escape }} image {{ forloop.index }}"
                  >
                    {{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: product.title }}
                  </button>
                {% endfor %}
              </div>
              {% if section.settings.show_prev_next_controls %}
                <button type="button" class="nv-media-gallery__nav nv-media-gallery__nav--next" data-media-nav="next" aria-label="Next image">
                  <span aria-hidden="true">›</span>
                </button>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="nv-product__info">
        <div class="nv-product__hero surface-panel nv-product__hero--align-{{ section.settings.buy_box_alignment }}">
          {% assign has_product_app_blocks = false %}
          {% for candidate_block in section.blocks %}
            {% if candidate_block.type == '@app' %}
              {% assign has_product_app_blocks = true %}
            {% endif %}
          {% endfor %}
          {% assign rendered_buy_box_chips = false %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when '@app' %}
                <div class="nv-product__block nv-product__block--app" data-nv-product-app-block {{ block.shopify_attributes }}>
                  <div class="nv-product__app-shell">
                    {% render block %}
                  </div>
                </div>

              {% when 'vendor' %}
                {% if product.vendor != blank %}
                  <div class="nv-product__block nv-product__block--vendor" {{ block.shopify_attributes }}>
                    <p class="eyebrow nv-product__vendor">{{ product.vendor | link_to_vendor }}</p>
                  </div>
                {% endif %}

              {% when 'title' %}
                <div class="nv-product__block nv-product__block--title" {{ block.shopify_attributes }}>
                  <div class="nv-product__title-block">
                    <h1 class="nv-product__title">{{ product.title }}</h1>
                    {% if section.settings.show_amazon_reviews_near_title and section.settings.show_reviews_app_slot %}
                      <div class="nv-product__reviews-slot" data-nv-reviews-slot hidden></div>
                    {% endif %}
                  </div>
                </div>

              {% when 'text' %}
                {% assign block_text = block.settings.text %}
                {% if block_text != blank %}
                  <div class="nv-product__block nv-product__block--text" {{ block.shopify_attributes }}>
                    <div class="rte nv-product__summary rte--compact">{{ block_text }}</div>
                  </div>
                {% endif %}

              {% when 'product_rating' %}
                {% if product_rating_value > 0 %}
                  <div class="nv-product__block nv-product__block--rating" {{ block.shopify_attributes }}>
                    <div class="nv-product__rating-row">
                      {% render 'rating-stars', rating: product_rating_value %}
                      {% if block.settings.show_count and product_rating_count != blank %}
                        <span class="nv-product__rating-count">({{ product_rating_count }})</span>
                      {% endif %}
                    </div>
                    {% if block.settings.show_reviews_anchor and has_product_app_blocks %}
                      <button type="button" class="nv-product__reviews-anchor" data-nv-reviews-anchor>
                        View reviews and product details
                      </button>
                    {% endif %}
                  </div>
                {% endif %}

              {% when 'price' %}
                <div class="nv-product__block nv-product__block--price" {{ block.shopify_attributes }}>
                  <div class="nv-product__price-panel">
                    <div class="nv-product__price-row">
                      <div class="nv-product__price">
                        {% render 'price', product: product, show_compare_at_price: block.settings.show_compare_at_price %}
                      </div>
                      {% if block.settings.show_sale_badge and current_variant.compare_at_price > current_variant.price %}
                        <span class="nv-product__sale-badge">Sale</span>
                      {% endif %}
                    </div>
                    {% if block.settings.show_prime_note %}
                      <div class="nv-product__prime-slot">
                        {% render 'nv-prime-tag-pdp', product: product, variant: current_variant %}
                      </div>
                    {% endif %}
                  </div>
                </div>

              {% when 'inventory_status' %}
                <div class="nv-product__block nv-product__block--inventory" {{ block.shopify_attributes }}>
                  <div class="nv-product__inventory {% unless current_variant.available %}is-unavailable{% endunless %}">
                    <span class="nv-product__inventory-dot" aria-hidden="true"></span>
                    <span class="nv-product__inventory-label">
                      {% if current_variant.available %}
                        {% if current_variant.inventory_management and current_variant.inventory_quantity > 0 and block.settings.show_quantity %}
                          {{ current_variant.inventory_quantity }} in stock
                        {% else %}
                          In stock
                        {% endif %}
                      {% else %}
                        Out of stock
                      {% endif %}
                    </span>
                  </div>
                </div>

              {% when 'shipping_line' %}
                {% if block.settings.text != blank %}
                  <div class="nv-product__block nv-product__block--shipping" {{ block.shopify_attributes }}>
                    <p class="nv-product__support-line">
                      {% if block.settings.icon != blank %}
                        <span class="nv-product__support-icon" aria-hidden="true">{{ block.settings.icon }}</span>
                      {% endif %}
                      <span>{{ block.settings.text }}</span>
                    </p>
                  </div>
                {% endif %}

              {% when 'payment_message' %}
                {% if block.settings.text != blank %}
                  <div class="nv-product__block nv-product__block--payment" {{ block.shopify_attributes }}>
                    <p class="nv-product__payment-line">{{ block.settings.text }}</p>
                  </div>
                {% endif %}

              {% when 'buy_box_chip' %}
                {% unless rendered_buy_box_chips %}
                  {% if buy_box_chip_blocks.size > 0 %}
                    <div class="nv-product__block nv-product__block--buy-box-chips" {{ block.shopify_attributes }}>
                      <div class="nv-product__buy-box-chips" aria-label="Product highlights">
                        {% for chip_block in buy_box_chip_blocks %}
                          {% if chip_block.settings.text != blank %}
                            <div class="nv-product__buy-box-chip" {{ chip_block.shopify_attributes }}>
                              <span class="nv-product__buy-box-chip-icon" aria-hidden="true">
                                {% if chip_block.settings.icon_image != blank %}
                                  {{ chip_block.settings.icon_image | image_url: width: 40 | image_tag: loading: 'lazy', alt: chip_block.settings.text }}
                                {% elsif chip_block.settings.icon_text != blank %}
                                  {{ chip_block.settings.icon_text }}
                                {% else %}
                                  ●
                                {% endif %}
                              </span>
                              <span class="nv-product__buy-box-chip-text">{{ chip_block.settings.text }}</span>
                            </div>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                  {% assign rendered_buy_box_chips = true %}
                {% endunless %}

              {% when 'product_meta_row' %}
                {% liquid
                  assign has_meta_row_item = false
                  if block.settings.show_brand_meta and product.vendor != blank
                    assign has_meta_row_item = true
                  endif
                  if block.settings.show_sku_meta and current_variant.sku != blank
                    assign has_meta_row_item = true
                  endif
                  if block.settings.show_type_meta and product.type != blank
                    assign has_meta_row_item = true
                  endif
                %}
                {% if has_meta_row_item %}
                  <div class="nv-product__block nv-product__block--meta-row" {{ block.shopify_attributes }}>
                    <div class="nv-product__meta-row" role="group" aria-label="Product details">
                      {% if block.settings.show_brand_meta and product.vendor != blank %}
                        <div class="nv-product__meta-row-item" data-meta-field="brand">
                          <span class="nv-product__meta-row-label">{{ block.settings.brand_label }}</span>
                          <span class="nv-product__meta-row-value">{{ product.vendor }}</span>
                        </div>
                      {% endif %}
                      {% if block.settings.show_sku_meta and current_variant.sku != blank %}
                        <div class="nv-product__meta-row-item" data-meta-field="sku">
                          <span class="nv-product__meta-row-label">{{ block.settings.sku_label }}</span>
                          <span class="nv-product__meta-row-value" data-current-sku>{{ current_variant.sku }}</span>
                        </div>
                      {% endif %}
                      {% if block.settings.show_type_meta and product.type != blank %}
                        <div class="nv-product__meta-row-item" data-meta-field="type">
                          <span class="nv-product__meta-row-label">{{ block.settings.type_label }}</span>
                          <span class="nv-product__meta-row-value">{{ product.type }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}

              {% when 'trust_strip' %}
                {% liquid
                  assign has_trust_items = false
                  if block.settings.item_1_text != blank or block.settings.item_2_text != blank or block.settings.item_3_text != blank or block.settings.item_4_text != blank
                    assign has_trust_items = true
                  endif
                %}
                {% if has_trust_items %}
                  <div
                    class="nv-product__block nv-product__block--trust-strip"
                    {{ block.shopify_attributes }}
                    style="--nv-trust-strip-size: {{ block.settings.trust_font_size }}px; --nv-trust-strip-icon-size: {{ block.settings.trust_icon_size }}px; --nv-trust-strip-color: {{ block.settings.trust_color }}; --nv-trust-strip-gap: {{ block.settings.trust_gap }}px;"
                  >
                    <div class="nv-trust-strip" role="list" aria-label="Purchase trust highlights">
                      {% for i in (1..4) %}
                        {% assign text_key = 'item_' | append: i | append: '_text' %}
                        {% assign icon_key = 'item_' | append: i | append: '_icon' %}
                        {% assign item_text = block.settings[text_key] %}
                        {% assign item_icon = block.settings[icon_key] | downcase | strip %}
                        {% if item_text != blank %}
                          <div class="nv-trust-strip__item" role="listitem">
                            <span class="nv-trust-strip__icon" aria-hidden="true">
                              {% case item_icon %}
                                {% when 'shipping', 'truck', 'free_shipping' %}
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2.5" y="6" width="11" height="9" rx="1.5"></rect>
                                    <path d="M13.5 9.5h3.8l2.2 2.4V15h-6"></path>
                                    <circle cx="7" cy="17.5" r="1.5"></circle>
                                    <circle cx="17" cy="17.5" r="1.5"></circle>
                                  </svg>
                                {% when 'payment', 'lock', 'secure_payment' %}
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="5.5" y="10" width="13" height="10" rx="2"></rect>
                                    <path d="M8.5 10V8a3.5 3.5 0 0 1 7 0v2"></path>
                                    <path d="M12 14.2v2.6"></path>
                                  </svg>
                                {% when 'natural', 'leaf', '100% natural' %}
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18.5 5.5c-6.2.4-10 4.3-10 9.5 0 2.6 1.8 4.5 4.5 4.5 5.1 0 9-3.9 9.5-10-.8-.2-2.3-.2-4 0Z"></path>
                                    <path d="M8.8 15.2c2.6-2.7 5.2-4.5 8.3-6"></path>
                                  </svg>
                                {% else %}
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="8"></circle>
                                    <path d="M8.8 12.2 11 14.4l4.4-4.4"></path>
                                  </svg>
                              {% endcase %}
                            </span>
                            <span class="nv-trust-strip__text">{{ item_text }}</span>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}

              {% when 'variant_picker' %}
                {% unless product.has_only_default_variant %}
                  <div class="nv-product__block nv-product__block--variant-picker" {{ block.shopify_attributes }}>
                    <div class="nv-product__option-group">
                      <label class="meta-label" for="ProductVariant-{{ section.id }}">{{ block.settings.label | default: 'Options' }}</label>
                      <div class="nv-product__select-wrap">
                        <select id="ProductVariant-{{ section.id }}" name="id" form="{{ product_form_id }}" class="nv-product__variant-select">
                          {% for variant in product.variants %}
                            {% liquid
                              assign variant_unit_text = ''
                              if variant.unit_price_measurement and variant.unit_price != blank
                                capture variant_unit_text
                                  echo variant.unit_price | money
                                  echo ' / '
                                  if variant.unit_price_measurement.reference_value != 1
                                    echo variant.unit_price_measurement.reference_value
                                  endif
                                  echo variant.unit_price_measurement.reference_unit
                                endcapture
                                assign variant_unit_text = variant_unit_text | strip
                              endif
                            %}
                            <option value="{{ variant.id }}" data-variant-sku="{{ variant.sku | escape }}" data-variant-barcode="{{ variant.barcode | escape }}" data-variant-price="{{ variant.price }}" data-variant-compare="{{ variant.compare_at_price | default: 0 }}" data-variant-unit="{{ variant_unit_text | escape }}" {% if variant.id == current_variant.id %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                              {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                            </option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>
                  </div>
                {% endunless %}

              {% when 'quantity_selector' %}
                {% unless has_buy_buttons_block %}
                  <div class="nv-product__block nv-product__block--quantity" {{ block.shopify_attributes }}>
                    <div class="nv-product__quantity-wrap">
                      <label class="meta-label" for="ProductQuantity-{{ section.id }}">{{ block.settings.label }}</label>
                      <div class="nv-product__quantity-control" data-qty-control>
                        <button type="button" class="nv-product__quantity-button" data-qty-change="-1" aria-label="Decrease quantity">−</button>
                        <input
                          id="ProductQuantity-{{ section.id }}"
                          class="nv-product__quantity-input"
                          type="number"
                          name="quantity"
                          value="1"
                          min="1"
                          inputmode="numeric"
                          form="{{ product_form_id }}"
                        >
                        <button type="button" class="nv-product__quantity-button" data-qty-change="1" aria-label="Increase quantity">+</button>
                      </div>
                    </div>
                  </div>
                {% endunless %}

              {% when 'buy_buttons' %}
                <div class="nv-product__block nv-product__block--buy-buttons" {{ block.shopify_attributes }}>
                  {% form 'product', product, id: product_form_id, class: 'nv-product__buy-form' %}
                    {% if product.has_only_default_variant or has_variant_picker_block == false %}
                      <input type="hidden" name="id" value="{{ current_variant.id }}">
                    {% endif %}
                    <div class="nv-product__cta-layout{% if has_quantity_selector_block %} has-quantity{% endif %}">
                      {% if has_quantity_selector_block %}
                        <div class="nv-product__quantity-wrap nv-product__quantity-wrap--inline">
                          <label class="meta-label" for="ProductQuantity-{{ section.id }}">{{ quantity_block_label }}</label>
                          <div class="nv-product__quantity-control" data-qty-control>
                            <button type="button" class="nv-product__quantity-button" data-qty-change="-1" aria-label="Decrease quantity">−</button>
                            <input
                              id="ProductQuantity-{{ section.id }}"
                              class="nv-product__quantity-input"
                              type="number"
                              name="quantity"
                              value="1"
                              min="1"
                              inputmode="numeric"
                            >
                            <button type="button" class="nv-product__quantity-button" data-qty-change="1" aria-label="Increase quantity">+</button>
                          </div>
                        </div>
                      {% endif %}
                      <div class="nv-product__cta">
                        <button
                          type="submit"
                          class="btn nv-product__atc-button"
                          data-nv-cta="add-to-cart"
                          {% unless product.available %}disabled{% endunless %}
                        >
                          {% if product.available %}{{ block.settings.button_label }}{% else %}Sold out{% endif %}
                        </button>
                      </div>
                    </div>
                  {% endform %}
                </div>

