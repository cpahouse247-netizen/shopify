                                  {% endif %}
                                {% endif %}
                              </span>
                              {% if block.settings.show_unit_text %}
                                <span class="nv-product__fbt-unit-text" data-fbt-item-unit data-default-text="{{ bundle_unit_text | escape }}" {% if bundle_unit_text == blank %}hidden{% endif %}>{{ bundle_unit_text }}</span>
                              {% endif %}
                              {% if block.settings.show_support_text and bundle_support_text != blank %}
                                <span class="nv-product__fbt-support">{{ bundle_support_text }}</span>
                              {% endif %}
                            </span>
                          </label>
                        {% endcapture %}
                        {% assign companion_markup = companion_markup | append: bundle_item_markup %}
                      {% endunless %}
                    {% endif %}
                  {% endfor %}
                {% endif %}

                {% if rendered_companion_count < max_bundle_items %}
                  {% for manual_product in (1..3) %}
                    {% if rendered_companion_count >= max_bundle_items %}
                      {% break %}
                    {% endif %}
                    {% assign product_key = 'product_' | append: manual_product %}
                    {% assign bundle_product = block.settings[product_key] %}
                    {% if bundle_product != blank and bundle_product.handle != product.handle %}
                      {% assign bundle_handle_token = '|' | append: bundle_product.handle | append: '|' %}
                      {% unless rendered_handles contains bundle_handle_token %}
                        {% assign rendered_handles = rendered_handles | append: bundle_product.handle | append: '|' %}
                        {% assign rendered_companion_count = rendered_companion_count | plus: 1 %}
                        {% assign bundle_variant = bundle_product.selected_or_first_available_variant %}
                        {% assign companion_slot = rendered_companion_count %}
                        {% assign override_title_key = 'override_title_' | append: companion_slot %}
                        {% assign unit_text_key = 'unit_text_' | append: companion_slot %}
                        {% assign support_text_key = 'support_text_' | append: companion_slot %}
                        {% assign bundle_title = block.settings[override_title_key] | default: bundle_product.metafields.custom.fbt_override_title.value | default: bundle_product.title %}
                        {% assign bundle_support_text = block.settings[support_text_key] | default: bundle_product.metafields.custom.fbt_support_text.value | default: bundle_product.metafields.custom.fbt_fulfillment_note.value | strip %}
                        {% assign bundle_unit_text = '' %}
                        {% if block.settings.show_unit_text %}
                          {% assign bundle_unit_text = block.settings[unit_text_key] | default: bundle_product.metafields.custom.fbt_unit_text.value | strip %}
                          {% if bundle_unit_text == blank and bundle_variant.unit_price_measurement and bundle_variant.unit_price != blank %}
                            {% capture bundle_unit_text %}
                              {{ bundle_variant.unit_price | money }} / {% if bundle_variant.unit_price_measurement.reference_value != 1 %}{{ bundle_variant.unit_price_measurement.reference_value }}{% endif %}{{ bundle_variant.unit_price_measurement.reference_unit }}
                            {% endcapture %}
                            {% assign bundle_unit_text = bundle_unit_text | strip %}
                          {% endif %}
                        {% endif %}
                        {% capture bundle_item_markup %}
