{%- liquid
  assign amazon_store_url = section.settings.amazon_store_url
  if amazon_store_url == blank
    assign amazon_store_url = settings.amazon_store_url
  endif
  if amazon_store_url == blank
    assign amazon_store_url = 'https://www.amazon.com/stores/NutraVora/page/E68A61C0-D855-4B15-ABB5-1E777FB44294'
  endif

  assign current_year = 'now' | date: '%Y'
  assign copyright_text = section.settings.copyright_text | replace: '2025', current_year
-%}

<footer class="nv-footer" role="contentinfo">
  {%- if section.settings.show_trust_bar -%}
    <div class="nv-footer__trust-bar">
      <div class="nv-footer__trust-bar-inner">
        {%- if section.settings.trust_item_1 != blank -%}
          <span class="nv-footer__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ section.settings.trust_item_1 }}
          </span>
        {%- endif -%}
        {%- if section.settings.trust_item_2 != blank -%}
          <span class="nv-footer__trust-separator" aria-hidden="true"></span>
          <span class="nv-footer__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ section.settings.trust_item_2 }}
          </span>
        {%- endif -%}
        {%- if section.settings.trust_item_3 != blank -%}
          <span class="nv-footer__trust-separator" aria-hidden="true"></span>
          <span class="nv-footer__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ section.settings.trust_item_3 }}
          </span>
        {%- endif -%}
        {%- if section.settings.trust_item_4 != blank -%}
          <span class="nv-footer__trust-separator" aria-hidden="true"></span>
          <span class="nv-footer__trust-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ section.settings.trust_item_4 }}
          </span>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="nv-footer__body">
    <div class="nv-footer__body-inner">
      <div class="nv-footer__brand">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
            {{
              settings.logo
              | image_url: width: 280
              | image_tag:
                loading: 'lazy',
                width: 140,
                height: 70,
                class: 'nv-footer__logo',
                alt: shop.name
            }}
          </a>
        {%- else -%}
          <a
            href="{{ routes.root_url }}"
            style="font-family: var(--nv-font-heading); font-size: 22px; color: var(--nv-white); text-decoration: none;"
          >
            {{ shop.name }}
          </a>
        {%- endif -%}

        {%- if section.settings.brand_tagline != blank -%}
          <p class="nv-footer__brand-tagline">
            {{ section.settings.brand_tagline }}
          </p>
        {%- endif -%}

        {%- if amazon_store_url != blank -%}
          <a href="{{ amazon_store_url }}" target="_blank" rel="noopener noreferrer" class="nv-footer__amazon-link">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            {{ section.settings.amazon_link_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.show_social -%}
          <div class="nv-footer__social">
            {%- if section.settings.social_instagram_url != blank -%}
              <a href="{{ section.settings.social_instagram_url }}" target="_blank" rel="noopener noreferrer" class="nv-footer__social-link" aria-label="Instagram">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_facebook_url != blank -%}
              <a href="{{ section.settings.social_facebook_url }}" target="_blank" rel="noopener noreferrer" class="nv-footer__social-link" aria-label="Facebook">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_tiktok_url != blank -%}
              <a href="{{ section.settings.social_tiktok_url }}" target="_blank" rel="noopener noreferrer" class="nv-footer__social-link" aria-label="TikTok">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_youtube_url != blank -%}
              <a href="{{ section.settings.social_youtube_url }}" target="_blank" rel="noopener noreferrer" class="nv-footer__social-link" aria-label="YouTube">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="var(--nv-green-dark)" stroke="none"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_column' -%}
            <div class="nv-footer__nav-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="nv-footer__nav-heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <ul class="nv-footer__nav-list">
                {%- for i in (1..6) -%}
                  {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                  {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                  {%- assign link_label = block.settings[label_key] -%}
                  {%- assign link_url = block.settings[url_key] -%}
                  {%- if link_label != blank -%}
                    <li>
                      <a
                        href="{{ link_url | default: '#' }}"
                        class="nv-footer__nav-link{% if link_label contains 'Amazon' %} nv-footer__nav-link--highlight{% endif %}"
                      >
                        {{ link_label }}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="nv-footer__nav-col">
          <h3 class="nv-footer__nav-heading">Products</h3>
          <ul class="nv-footer__nav-list">
            <li><a class="nv-footer__nav-link" href="/products/nutravora-oil-of-oregano-with-black-seed-oil-capsules-dietary-supplement-for-immune-respiratory-wellness-support-with-carvacrol-thymoquinone-non-gmo-gluten-free-300-softgels">Oil of Oregano</a></li>
            <li><a class="nv-footer__nav-link" href="/products/nutravora-triple-strength-omega-3-fish-oil-4200-mg-per-serving-with-1300-mg-epa-850-mg-dha-lemon-flavor-burpless-formula-wild-caught-non-gmo-gluten-free-300-softgels">Omega-3 Fish Oil</a></li>
            <li><a class="nv-footer__nav-link" href="/products/nutravora-pumpkin-seed-oil-saw-palmetto-300-softgels">Pumpkin Seed Oil</a></li>
            <li><a class="nv-footer__nav-link" href="{{ routes.all_products_collection_url }}">All Products</a></li>
          </ul>
        </div>
        <div class="nv-footer__nav-col">
          <h3 class="nv-footer__nav-heading">Company</h3>
          <ul class="nv-footer__nav-list">
            <li><a class="nv-footer__nav-link" href="/pages/about">About NutraVora</a></li>
            <li><a class="nv-footer__nav-link" href="/pages/quality">Our Quality Standard</a></li>
            <li><a class="nv-footer__nav-link" href="/blogs/news">Wellness Blog</a></li>
            <li><a class="nv-footer__nav-link" href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>
        <div class="nv-footer__nav-col">
          <h3 class="nv-footer__nav-heading">Support</h3>
          <ul class="nv-footer__nav-list">
            <li><a class="nv-footer__nav-link" href="/pages/faq">FAQ</a></li>
            <li><a class="nv-footer__nav-link" href="/policies/shipping-policy">Shipping Policy</a></li>
            <li><a class="nv-footer__nav-link" href="/policies/refund-policy">Refund Policy</a></li>
            <li><a class="nv-footer__nav-link" href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a class="nv-footer__nav-link nv-footer__nav-link--highlight" href="{{ amazon_store_url }}" target="_blank" rel="noopener noreferrer">Shop on Amazon -&gt;</a></li>
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_newsletter -%}
    <div class="nv-footer__newsletter">
      <div class="nv-footer__newsletter-inner">
        <div class="nv-footer__newsletter-copy">
          <h3 class="nv-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h3>
          <p class="nv-footer__newsletter-sub">{{ section.settings.newsletter_sub }}</p>
        </div>
        {% form 'customer', class: 'nv-footer__newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="nv-footer__newsletter-input"
            placeholder="{{ section.settings.newsletter_placeholder }}"
            required
            autocomplete="email"
            aria-label="Email address"
          >
          <button type="submit" class="nv-footer__newsletter-btn">
            {{ section.settings.newsletter_btn_label }}
          </button>
        {% endform %}
      </div>
    </div>
  {%- endif -%}

  <div class="nv-footer__bottom">
    <div class="nv-footer__bottom-inner">
      <p class="nv-footer__copyright">{{ copyright_text }}</p>
      <nav class="nv-footer__legal-links" aria-label="Legal">
        <a href="/policies/privacy-policy" class="nv-footer__legal-link">Privacy Policy</a>
        <a href="/policies/terms-of-service" class="nv-footer__legal-link">Terms of Service</a>
        <a href="/policies/refund-policy" class="nv-footer__legal-link">Refund Policy</a>
        <a href="/policies/shipping-policy" class="nv-footer__legal-link">Shipping Policy</a>
      </nav>
      <div class="nv-footer__payment-icons">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'nv-footer__payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

