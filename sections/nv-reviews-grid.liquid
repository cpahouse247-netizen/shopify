    },
    {
      "type": "color",
      "id": "card_divider_color",
      "label": "Card divider color",
      "default": "#BCD19F"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#C8A96B"
    },
    {
      "type": "color",
      "id": "reviewer_name_color",
      "label": "Reviewer name color",
      "default": "#1F3A2F"
    },
    {
      "type": "color",
      "id": "linked_product_color",
      "label": "Linked product color",
      "default": "#315C4A"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 26,
      "max": 60,
      "step": 1,
      "default": 34,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading font size",
      "min": 13,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_name_font_size",
      "label": "Reviewer name font size",
