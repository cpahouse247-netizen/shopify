{%- liquid
  assign primary_url = section.settings.primary_cta_url | default: 'https://www.amazon.com/stores/NutraVora/page/E68A61C0-D855-4B15-ABB5-1E777FB44294'
  assign secondary_url = section.settings.secondary_cta_url | default: '/collections/all'
-%}

<section class="nv-lp-hero">
  <div class="nv-lp-hero__bg">
    {%- if section.settings.hero_image -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1440 }}"
        alt="{{ section.settings.heading | escape }}"
        class="nv-lp-hero__bg-img nv-lp-hero__bg-img--desktop"
        loading="eager"
        fetchpriority="high"
        width="1440"
        height="640"
      >
    {%- endif -%}
    {%- if section.settings.hero_image_mobile -%}
      <img
        src="{{ section.settings.hero_image_mobile | image_url: width: 768 }}"
        alt="{{ section.settings.heading | escape }}"
        class="nv-lp-hero__bg-img nv-lp-hero__bg-img--mobile"
        loading="eager"
        width="768"
        height="560"
      >
    {%- endif -%}
    <div class="nv-lp-hero__overlay"></div>
  </div>

  <div class="nv-lp-hero__content">
    <div class="nv-lp-hero__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="nv-eyebrow nv-lp-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h1 class="nv-lp-hero__heading">{{ section.settings.heading }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="nv-lp-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.show_rating_bar -%}
        <div class="nv-lp-hero__rating">
          <div class="nv-lp-hero__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#c8a96b">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {%- endfor -%}
          </div>
          <span class="nv-lp-hero__rating-text">{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}

      <div class="nv-lp-hero__cta-group">
        {%- if section.settings.primary_cta_label != blank -%}
          <a href="{{ primary_url }}" target="_blank" rel="noopener noreferrer" class="nv-lp-hero__cta-primary nv-btn nv-btn--amazon nv-btn--xl nv-btn--pulse">
            {{ section.settings.primary_cta_label | remove: '→' | strip }} <span class="nv-btn__amazon-arrow">→</span>
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          <a href="{{ secondary_url }}" class="nv-lp-hero__cta-secondary nv-btn nv-btn--outline-white nv-btn--xl">
            {{ section.settings.secondary_cta_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_money_back -%}
        <p class="nv-lp-hero__guarantee">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          {{ section.settings.money_back_text }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .nv-lp-hero {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--nv-green-dark), var(--nv-green-primary));
    overflow: hidden;
  }

  .nv-lp-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .nv-lp-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .nv-lp-hero__bg-img--mobile {
    display: none;
  }

  .nv-lp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15, 17, 19, 0.75) 0%,
      rgba(15, 17, 19, 0.40) 55%,
      rgba(15, 17, 19, 0.10) 100%
    );
  }

  .nv-lp-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 80px 0;
  }

  .nv-lp-hero__inner {
    max-width: 600px;
    padding: 0 var(--nv-space-6);
    margin-left: max(24px, calc((100vw - 1280px) / 2 + 24px));
  }

  .nv-lp-hero__eyebrow {
    color: var(--nv-gold-light);
  }

  .nv-lp-hero__heading {
    font-family: var(--nv-font-heading);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: var(--nv-weight-regular);
    line-height: var(--nv-leading-tight);
    color: var(--nv-white);
    margin: 12px 0 16px;
  }

  .nv-lp-hero__subheading {
    font-size: 16px;
    line-height: var(--nv-leading-relaxed);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 24px;
    max-width: 480px;
  }

  .nv-lp-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 28px;
  }

  .nv-lp-hero__stars {
    display: flex;
    gap: 2px;
  }

  .nv-lp-hero__rating-text {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.80);
    font-weight: var(--nv-weight-medium);
  }

  .nv-lp-hero__cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .nv-lp-hero__cta-primary,
  .nv-lp-hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: var(--nv-radius-lg);
    font-size: 15px;
    font-weight: var(--nv-weight-semibold);
    transition: all var(--nv-duration-base) var(--nv-ease-default);
  }

  .nv-lp-hero__cta-primary {
    padding: 15px 32px;
    background: var(--nv-gold-primary);
    color: var(--nv-text-primary);
    letter-spacing: 0.03em;
  }

  .nv-lp-hero__cta-primary:hover {
    background: var(--nv-gold-dark);
    transform: translateY(-2px);
    box-shadow: var(--nv-shadow-gold);
  }

  .nv-lp-hero__cta-secondary {
    padding: 13px 28px;
    background: transparent;
    color: var(--nv-white);
    border: 2px solid rgba(255, 255, 255, 0.6);
  }

  .nv-lp-hero__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.10);
    border-color: var(--nv-white);
  }

  .nv-lp-hero__guarantee {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  @media (max-width: 768px) {
    .nv-lp-hero {
      min-height: 520px;
    }

    .nv-lp-hero__bg-img--desktop {
      display: none;
    }

    .nv-lp-hero__bg-img--mobile {
      display: block;
    }

    .nv-lp-hero__inner {
      margin-left: 0;
      padding: 0 var(--nv-space-5);
    }

    .nv-lp-hero__overlay {
      background: rgba(15, 17, 19, 0.60);
    }

    .nv-lp-hero__cta-primary,
    .nv-lp-hero__cta-secondary {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "LP Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "NutraVora Premium Supplements" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Natural Immune Support You Can Trust" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Third-party tested. Non-GMO. Gluten-free. Trusted by thousands of daily wellness routines." },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label", "default": "Shop on Amazon →" },
    { "type": "url", "id": "primary_cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "See Our Products" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary CTA URL", "default": "/collections/all" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "image_picker", "id": "hero_image_mobile", "label": "Hero image mobile" },
    { "type": "checkbox", "id": "show_rating_bar", "label": "Show rating bar", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.8★ rated · 1,000+ Amazon reviews" },
    { "type": "checkbox", "id": "show_money_back", "label": "Show money-back guarantee", "default": true },
    { "type": "text", "id": "money_back_text", "label": "Money-back text", "default": "30-Day Satisfaction Guarantee" }
  ],
  "presets": [
    { "name": "LP Hero" }
  ]
}
{% endschema %}
