{{ 'product-marketplace.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_media = current_variant.featured_media | default: product.featured_media | default: product.media.first
  assign product_form_id = 'nv-premium-product-form-' | append: section.id
  assign conversion_mode_override = section.settings.cta_mode | strip

  case section.settings.buybox_layout_density
    when 'compact'
      assign buybox_block_spacing = 14
      assign buybox_form_spacing = 12
    when 'airy'
      assign buybox_block_spacing = 20
      assign buybox_form_spacing = 16
    else
      assign buybox_block_spacing = 16
      assign buybox_form_spacing = 14
  endcase

  assign amazon_fallback_link = section.settings.amazon_fallback_link | strip
  # NutraVora Amazon URL Resolver
  assign nv_amazon_url = product.metafields.custom.amazon_attribution_link.value | default: product.metafields.custom.amazon_attribution_link | strip
  if nv_amazon_url == blank
    assign nv_amazon_url = amazon_fallback_link
  endif
  if nv_amazon_url == blank
    assign nv_amazon_url = settings.amazon_store_url | strip
  endif
  assign nv_has_amazon = false
  if nv_amazon_url != blank
    assign nv_has_amazon = true
  endif

  assign hero_subheadline_fallback = section.settings.hero_subheadline_fallback | default: 'Premium daily wellness formula' | strip
  assign hero_spotlight_fallback = section.settings.hero_spotlight_fallback | default: 'A clean-label formula designed for consistent daily use.' | strip
  assign hero_trust_badges_fallback = section.settings.hero_trust_badges_fallback | default: 'Non-GMO | Gluten-Free | Lab Tested' | strip

  assign hero_subheadline = product.metafields.custom.hero_subheadline.value | default: product.metafields.custom.hero_subheadline | default: hero_subheadline_fallback | strip

  assign spotlight_lines = blank
  assign spotlight_source = product.metafields.custom.hero_spotlight_bullets.value | default: product.metafields.custom.hero_spotlight_bullets
  if spotlight_source != blank
    assign spotlight_source = spotlight_source | metafield_tag | strip_html | newline_to_br | split: '<br />'
    assign spotlight_lines = spotlight_source
  elsif hero_spotlight_fallback != blank
    assign spotlight_lines = hero_spotlight_fallback | newline_to_br | split: '<br />'
  endif

  assign trust_badge_lines = blank
  assign trust_badges_source = product.metafields.custom.hero_trust_badges.value | default: product.metafields.custom.hero_trust_badges
  if trust_badges_source != blank
    assign trust_badges_source = trust_badges_source | metafield_tag | strip_html | newline_to_br | split: '<br />'
    assign trust_badge_lines = trust_badges_source
  elsif hero_trust_badges_fallback != blank
    assign trust_badge_lines = hero_trust_badges_fallback | split: '|'
  endif

  assign product_rating_value = 0
  assign product_rating_count = blank
  if product.metafields.reviews.rating.value != blank
    assign rating_object = product.metafields.reviews.rating.value
    assign product_rating_value = rating_object.rating | default: rating_object
  elsif product.metafields.custom.rating != blank
    assign product_rating_value = product.metafields.custom.rating.value | default: product.metafields.custom.rating
  endif
  if product.metafields.reviews.rating_count.value != blank
    assign product_rating_count = product.metafields.reviews.rating_count.value
  elsif product.metafields.reviews.rating_count != blank
    assign product_rating_count = product.metafields.reviews.rating_count
  endif

  assign recommendation_text = product.metafields.custom.recommendation_text.value | default: product.metafields.custom.recommendation_text | strip
  assign bought_text = product.metafields.custom.bought_count_text.value | default: product.metafields.custom.bought_count_text | strip
  assign fulfillment_note = product.metafields.custom.fulfillment_note.value | default: product.metafields.custom.fulfillment_note | default: product.metafields.custom.imported_note.value | default: product.metafields.custom.imported_note | default: product.metafields.custom.import_note.value | default: product.metafields.custom.import_note | strip
  assign item_number = product.metafields.custom.item_number.value | default: product.metafields.custom.item_number | strip
  assign nv_supply_label = product.metafields.custom.supply_label.value | default: product.metafields.custom.supply_label | default: settings.default_supply_label | strip
  assign nv_product_rating_data = product.metafields.custom.rating.value | default: product.metafields.custom.rating | default: product_rating_value | default: settings.default_rating | default: '4.8' | strip
  assign nv_product_review_count_data = product.metafields.custom.review_count.value | default: product.metafields.custom.review_count | default: product_rating_count | default: settings.default_review_count | default: '221+' | strip
  if nv_product_rating_data == blank or nv_product_rating_data == '0'
    assign nv_product_rating_data = settings.default_rating | default: '4.8' | strip
  endif
  if nv_product_review_count_data == blank
    assign nv_product_review_count_data = settings.default_review_count | default: '221+' | strip
  endif

-%}

<script>
  window.__nv_product_data = {
    id: {{ product.id | json }},
    title: {{ product.title | json }},
    vendor: {{ product.vendor | json }},
    type: {{ product.type | json }},
    price: {{ product.selected_or_first_available_variant.price | json }},
    sku: {{ product.selected_or_first_available_variant.sku | json }},
    handle: {{ product.handle | json }},
    available: {{ product.available | json }},
    amazon_url: {{ nv_amazon_url | json }}
  };
</script>

<section
  id="MainProductPremium-{{ section.id }}"
  class="section nv-pdp nv-pdp--premium{% unless section.settings.buybox_sticky %} nv-pdp--buybox-static{% endunless %}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-nv-product-id="{{ product.id }}"
  data-nv-product-handle="{{ product.handle }}"
  data-nv-supply-label="{{ nv_supply_label | escape }}"
  data-nv-product-rating="{{ nv_product_rating_data | escape }}"
  data-nv-product-review-count="{{ nv_product_review_count_data | escape }}"
  data-nv-has-amazon="{{ nv_has_amazon }}"
  style="
    --nv-buybox-max-width: {{ section.settings.buybox_max_width }}px;
    --nv-buybox-title-size: {{ section.settings.buybox_title_size }}px;
    --nv-buybox-body-size: {{ section.settings.buybox_body_size }}px;
    --nv-buybox-button-radius: {{ section.settings.buybox_button_radius }}px;
    --nv-buybox-button-gap: {{ section.settings.buybox_button_spacing }}px;
    --nv-buybox-block-spacing: {{ buybox_block_spacing }}px;
    --nv-buybox-form-spacing: {{ buybox_form_spacing }}px;
  "
>
  <div class="container container--wide nv-pdp__container">
    {% if section.settings.show_breadcrumbs %}
      {% render 'nv-pdp-breadcrumbs', product: product, collection: collection %}
    {% endif %}

    <div class="nv-pdp-hero nv-pdp-hero--editorial">
      {% render 'nv-pdp-gallery',
        product: product,
        current_variant: current_variant,
        featured_media: featured_media,
        section_id: section.id
      %}

      {% render 'nv-pdp-buybox',
        product: product,
        current_variant: current_variant,
        product_form_id: product_form_id,
        template_override: conversion_mode_override,
        review_rating: product_rating_value,
        review_count: product_rating_count,
        recommendation_text: recommendation_text,
        bought_count_text: bought_text,
        item_number: item_number,
        hero_subheadline: hero_subheadline,
        hero_spotlight_lines: spotlight_lines,
        hero_trust_badge_lines: trust_badge_lines,
        fulfillment_note: fulfillment_note,
        amazon_fallback_link: nv_amazon_url,
        section: section
      %}
    </div>

    {% render 'nv-pdp-standout-metafields', product: product %}
    {% render 'nv-pdp-product-details-metafields', product: product %}
    {% render 'nv-pdp-important-info-metafields', product: product %}
    {% render 'nv-pdp-who-should-buy-metafields', product: product %}
    {% render 'nv-pdp-dietary-disclaimer-metafields', product: product %}
    {% render 'nv-pdp-qa-metafields', product: product %}
    {% render 'nv-pdp-editorial-summary-metafields', product: product %}
    {% render 'nv-pdp-related-products', product: product %}

    <section class="nv-pdp-areviews" data-nv-areviews-section>
      <div id="Areviewsapp" class="nv-pdp-areviews__widget page-full">
        <div
          id="az_reviews"
          class="az_reviews AReviewsApp"
          data-product_id="{{ product.id }}"
          data-product-id="{{ product.id }}"
          data-product-handle="{{ product.handle | escape }}"
        ></div>
      </div>
    </section>
  </div>

  {% render 'nv-product-sticky-cta', product: product, template_override: conversion_mode_override, product_form_id: product_form_id %}
  {%- if nv_has_amazon -%}
    <div
      class="nv-mobile-amazon-bar"
      aria-hidden="true"
      style="
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 12px 16px;
        padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
        background: var(--nv-white);
        border-top: 1px solid var(--nv-border-light);
        box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
        z-index: calc(var(--nv-z-sticky) - 1);
      "
    >
      <a href="{{ nv_amazon_url }}" target="_blank" rel="noopener noreferrer" class="nv-btn nv-btn--amazon nv-btn--full nv-btn--lg">
        Buy on Amazon — Prime Eligible →
      </a>
    </div>
  {%- endif -%}
</section>

