</style>

<script>
  (function() {
    const sectionRoot = document.getElementById('MainProductPremium-{{ section.id }}');
    if (!sectionRoot) return;

    const gallery = document.getElementById('nvPremiumMediaGallery-{{ section.id }}');
    const featuredImage = document.getElementById('nvPremiumFeaturedImage-{{ section.id }}');
    if (gallery && featuredImage) {
      const thumbs = Array.from(gallery.querySelectorAll('[data-media-thumb]'));
      const prev = gallery.querySelector('[data-media-nav="prev"]');
      const next = gallery.querySelector('[data-media-nav="next"]');
      let activeIndex = Math.max(thumbs.findIndex((thumb) => thumb.classList.contains('is-active')), 0);

      const setActive = (index) => {
        const thumb = thumbs[index];
        if (!thumb) return;
        const src = thumb.getAttribute('data-media-src');
        const alt = thumb.getAttribute('data-media-alt');
        if (src) featuredImage.src = src;
        if (alt) featuredImage.alt = alt;
        thumbs.forEach((item) => item.classList.remove('is-active'));
        thumb.classList.add('is-active');
        activeIndex = index;
        thumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      };

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => setActive(index));
      });

      if (prev) {
        prev.addEventListener('click', () => {
          setActive(activeIndex <= 0 ? thumbs.length - 1 : activeIndex - 1);
        });
      }

      if (next) {
        next.addEventListener('click', () => {
          setActive(activeIndex >= thumbs.length - 1 ? 0 : activeIndex + 1);
        });
      }
    }

    sectionRoot.querySelectorAll('[data-qty-control]').forEach((control) => {
      const input = control.querySelector('input[type="number"]');
      if (!input) return;
      control.querySelectorAll('[data-qty-change]').forEach((button) => {
        button.addEventListener('click', () => {
          if (button.disabled || input.disabled) return;
          const delta = Number(button.getAttribute('data-qty-change') || '0');
          const currentValue = Number(input.value || '1');
          const nextValue = Math.max(1, currentValue + delta);
          input.value = String(nextValue);
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });
    });

    const variantSelect = sectionRoot.querySelector('#PremiumProductVariant-{{ section.id }}');
    if (variantSelect) {
      variantSelect.addEventListener('change', (event) => {
        const variantId = event.target.value;
        if (!variantId) return;
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('variant', variantId);
        window.location.href = nextUrl.toString();
      });
    }

    sectionRoot.querySelectorAll('[data-nv-areviews-scroll]').forEach((button) => {
      button.addEventListener('click', () => {
        const reviews = sectionRoot.querySelector('[data-nv-areviews-section]');
        if (reviews) reviews.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      button.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        const reviews = sectionRoot.querySelector('[data-nv-areviews-section]');
        if (reviews) reviews.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    const areviewsStars = sectionRoot.querySelector('.areviews_header_stars');
    const ratingFallback = sectionRoot.querySelector('[data-nv-rating-fallback]');
    if (areviewsStars && ratingFallback) {
      const syncRatingFallback = () => {
        const hasRenderedStars = areviewsStars.textContent.trim() !== '' || areviewsStars.children.length > 0;
        ratingFallback.hidden = hasRenderedStars;
      };
      syncRatingFallback();
      new MutationObserver(syncRatingFallback).observe(areviewsStars, { childList: true, subtree: true, characterData: true });
    }
  })();
</script>

