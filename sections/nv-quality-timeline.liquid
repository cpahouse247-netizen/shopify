{%- assign timeline_class = '' -%}
{%- if section.settings.background_style == 'light' -%}
  {%- assign timeline_class = 'nv-timeline--light' -%}
{%- endif -%}

<section class="nv-timeline {{ timeline_class }}" id="section-{{ section.id }}">
  <div class="nv-timeline__inner">
    <div class="nv-timeline__header" data-nv-animate="fade-up">
      {%- if section.settings.eyebrow != blank -%}
        <span class="nv-eyebrow nv-timeline__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="nv-section-heading nv-timeline__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="nv-section-subheading nv-timeline__subheading">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}
    </div>

    <div class="nv-timeline__track">
      {%- for block in section.blocks -%}
        {%- assign delay = forloop.index0 | times: 150 | plus: 200 -%}
        {%- if delay > 800 -%}
          {%- assign delay = 800 -%}
        {%- endif -%}

        <div
          class="nv-timeline__step"
          data-nv-animate="fade-up"
          data-nv-delay="{{ delay }}"
          {{ block.shopify_attributes }}
        >
          <div class="nv-timeline__step-content">
            {%- if block.settings.step_label != blank -%}
              <span class="nv-timeline__step-label">
                {{ block.settings.step_label }}
              </span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="nv-timeline__step-title">
                {{ block.settings.title }}
              </h3>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="nv-timeline__step-body">
                {{ block.settings.body }}
              </p>
            {%- endif -%}
          </div>

          <div class="nv-timeline__step-node">
            <div class="nv-timeline__step-dot">
              {{ block.settings.icon }}
            </div>
            <span class="nv-timeline__step-number">
              {{ forloop.index }}
            </span>
          </div>

          <div class="nv-timeline__step-visual">
            <div class="nv-timeline__step-card">
              {%- if block.settings.step_image != blank -%}
                {{
                  block.settings.step_image
                  | image_url: width: 440
                  | image_tag:
                    loading: 'lazy',
                    widths: '200,400',
                    sizes: '220px',
                    class: 'nv-timeline__step-card-image',
                    alt: block.settings.title
                }}
              {%- else -%}
                <span class="nv-timeline__step-card-icon">
                  {{ block.settings.icon }}
                </span>
              {%- endif -%}

              {%- if block.settings.card_label != blank -%}
                <span class="nv-timeline__step-card-label">
                  {{ block.settings.card_label }}
                </span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_bottom_cta and section.settings.cta_label != blank -%}
      <div class="nv-timeline__cta" data-nv-animate="fade-up" data-nv-delay="800">
        <a
          href="{{ section.settings.cta_url | default: '/collections/all' }}"
          class="nv-btn nv-btn--outline-white nv-btn--lg"
        >
          {{ section.settings.cta_label }}
          <span class="nv-btn__icon--right">-></span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "NV Quality Timeline",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Quality Standard"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Source to Softgel"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A rigorous process ensures every NutraVora formula meets our premium quality standard."
    },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background",
      "default": "dark",
      "options": [
        {
          "value": "dark",
          "label": "Dark Green"
        },
        {
          "value": "light",
          "label": "Light Cream"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_bottom_cta",
      "label": "Show bottom CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "See Our Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "timeline_step",
      "name": "Timeline step",
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Step label (e.g. Step 01)",
          "default": "Step 01"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Ingredient Sourcing"
        },
        {
          "type": "text",
          "id": "body",
          "label": "Step description",
          "default": "We source each ingredient from verified suppliers with documented purity standards."
        },
        {
          "type": "text",
          "id": "card_label",
          "label": "Visual card label",
          "default": "Verified Suppliers"
        },
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NV Quality Timeline",
      "blocks": [
        {
          "type": "timeline_step",
          "settings": {
            "step_label": "Step 01",
            "icon": "🌿",
            "title": "Ingredient Sourcing",
            "body": "Each ingredient is selected from verified suppliers with documented purity and potency standards.",
            "card_label": "Verified Suppliers"
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_label": "Step 02",
            "icon": "🔬",
            "title": "Third-Party Testing",
            "body": "Every batch is independently tested by accredited labs before production begins.",
            "card_label": "Independent Lab Verified"
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_label": "Step 03",
            "icon": "🏭",
            "title": "GMP Manufacturing",
            "body": "Produced in a GMP-certified facility under strict quality control protocols.",
            "card_label": "GMP Certified Facility"
          }
        },
        {
          "type": "timeline_step",
          "settings": {
            "step_label": "Step 04",
            "icon": "✅",
            "title": "Final Quality Check",
            "body": "Each finished product undergoes a final review before it reaches your door.",
            "card_label": "Quality Assured"
          }
        }
      ]
    }
  ]
}
{% endschema %}
