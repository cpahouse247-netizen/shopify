{% liquid
  assign selected_menu = section.settings.main_menu
  if selected_menu == blank
    assign selected_menu = section.settings.left_menu
  endif
  assign nav_links = linklists[selected_menu].links
  assign amazon_label = section.settings.amazon_store_label | strip
  assign amazon_link = section.settings.amazon_store_link
  assign mobile_logo_alignment = section.settings.mobile_header_alignment | default: 'left'
  assign mobile_menu_label = section.settings.mobile_menu_label | default: 'Menu'
  assign mobile_amazon_label = section.settings.mobile_amazon_button_label | default: amazon_label | default: 'Amazon Store'
  assign mobile_amazon_link = section.settings.mobile_amazon_button_link
  if mobile_amazon_link == blank
    assign mobile_amazon_link = amazon_link
  endif
  assign shop_link = routes.all_products_collection_url | default: '/collections/all'
  assign request_path = request.path | default: ''
%}

<header id="custom-header-{{ section.id }}" class="custom-header{% if section.settings.enable_sticky_top_row %} custom-header--sticky-top-row{% endif %} custom-header--logo-{{ section.settings.logo_alignment }} custom-header--nav-{{ section.settings.nav_alignment }} custom-header--utility-{{ section.settings.utility_alignment }} custom-header--mobile-{{ mobile_logo_alignment }} custom-header--hover-{{ section.settings.nav_hover_style }}" role="banner">
  <div class="custom-header__shell">
    <div class="custom-header__top custom-header__top-row">
      <div class="custom-header__mobile-left">
        {% if nav_links != blank %}
          <button
            type="button"
            class="custom-header__menu-trigger"
            aria-expanded="false"
            aria-controls="custom-header-drawer-{{ section.id }}"
            aria-label="Open menu"
          >
            <svg class="custom-header__menu-trigger-open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"/>
            </svg>
            <svg class="custom-header__menu-trigger-close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"/>
            </svg>
            <span class="custom-header__menu-trigger-label">{{ mobile_menu_label }}</span>
          </button>
        {% endif %}
      </div>

      <div class="custom-header__mobile-center">
        <div class="custom-header__brand">
          <a href="{{ routes.root_url }}" class="custom-header__logo-link" aria-label="{{ shop.name }}">
            {% if section.settings.header_logo != blank %}
              <img
                src="{{ section.settings.header_logo | image_url: width: 420 }}"
                alt="{{ shop.name }}"
                class="custom-header__logo-image"
                loading="eager"
                style="max-width: {{ section.settings.header_logo_width }}px;"
              >
            {% elsif section.settings.logo != blank %}
              <img
                src="{{ section.settings.logo | image_url: width: 420 }}"
                alt="{{ shop.name }}"
                class="custom-header__logo-image"
                loading="eager"
                style="max-width: {{ section.settings.header_logo_width }}px;"
              >
            {% else %}
              <span class="custom-header__logo-wordmark">{{ shop.name }}</span>
            {% endif %}
          </a>
        </div>
      </div>

      <div class="custom-header__mobile-right">
        {% if section.settings.show_mobile_amazon_button and mobile_amazon_label != blank and mobile_amazon_link != blank %}
          <a href="{{ mobile_amazon_link }}" target="_blank" rel="noopener noreferrer" class="custom-header__mobile-amazon">
            <span>{{ mobile_amazon_label }}</span>
          </a>
        {% endif %}
        <div class="custom-header__actions">
        {% if section.settings.show_amazon_store_link and amazon_label != blank and amazon_link != blank %}
          <a href="{{ amazon_link }}" target="_blank" rel="noopener noreferrer" class="custom-header__utility-link custom-header__utility-link--amazon">
            <span>{{ amazon_label }}</span>
          </a>
        {% endif %}

        <div class="custom-header__utility-links">
          {% if section.settings.show_search_icon %}
            <a href="{{ routes.search_url }}" class="custom-header__utility-link custom-header__utility-link--search" aria-label="Search">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M17.25 17.25 21 21m-9.75-2.25a6.75 6.75 0 1 1 0-13.5 6.75 6.75 0 0 1 0 13.5Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
              </svg>
              <span>Search</span>
            </a>
          {% endif %}

          {% if section.settings.show_account_icon %}
            <a href="{{ routes.account_login_url }}" class="custom-header__utility-link" aria-label="Account">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M12 12a4.25 4.25 0 1 0 0-8.5 4.25 4.25 0 0 0 0 8.5Zm0 2c-4.26 0-7.5 2.31-7.5 5.1 0 .5.4.9.9.9h13.2c.5 0 .9-.4.9-.9C19.5 16.31 16.26 14 12 14Z" fill="currentColor"/>
              </svg>
              <span>Account</span>
            </a>
          {% endif %}

          {% if section.settings.show_cart_icon and settings.amazon_hide_cart != true %}
            <a href="{{ routes.cart_url }}" class="custom-header__utility-link custom-header__utility-link--cart" aria-label="Cart" data-nv-cart-drawer-open>
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M3.75 5.25h1.8l1.68 9.24a1.5 1.5 0 0 0 1.48 1.23h7.82a1.5 1.5 0 0 0 1.46-1.16l1.32-5.64a1.5 1.5 0 0 0-1.46-1.84H7.37" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                <circle cx="10" cy="19" r="1.25" fill="currentColor"/>
                <circle cx="17" cy="19" r="1.25" fill="currentColor"/>
              </svg>
              <span>Cart</span>
              {% if cart.item_count > 0 %}
                <span class="custom-header__cart-count" aria-hidden="true" data-nv-cart-badge>{{ cart.item_count }}</span>
              {% endif %}
            </a>
          {% endif %}
        </div>
        </div>
      </div>
    </div>

    {% if nav_links != blank %}
      <div class="custom-header__bottom custom-header__bottom-row">
        <nav class="custom-header__menu custom-header__menu--desktop custom-header__desktop-nav" aria-label="Primary navigation">
          <ul class="custom-header__menu-list">
            {% for link in nav_links %}
              {% assign submenu_id = 'custom-header-submenu-' | append: section.id | append: '-' | append: forloop.index %}
              <li class="custom-header__menu-item{% if link.links != blank %} custom-header__menu-item--has-children{% endif %}">
                {% if link.links != blank %}
                  <div class="custom-header__menu-link-row">
                    <a href="{{ link.url }}" class="custom-header__menu-link custom-header__menu-link--parent">{{ link.title }}</a>
                    <button
                      type="button"
                      class="custom-header__submenu-toggle"
                      aria-expanded="false"
                      aria-controls="{{ submenu_id }}"
                      aria-label="Toggle {{ link.title }} submenu"
                    >
                      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path d="M4 6.5 8 10.5l4-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                      </svg>
                    </button>
                  </div>
                  <div id="{{ submenu_id }}" class="custom-header__submenu" aria-label="{{ link.title }} submenu">
                    <ul class="custom-header__submenu-list" role="list">
                      {% for child_link in link.links %}
                        <li class="custom-header__submenu-item">
                          <a href="{{ child_link.url }}" class="custom-header__submenu-link">{{ child_link.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% else %}
                  <a href="{{ link.url }}" class="custom-header__menu-link">{{ link.title }}</a>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    {% endif %}

    {% if nav_links != blank %}
      <div class="custom-header__drawer-backdrop" data-mobile-menu-backdrop aria-hidden="true"></div>
      <div
        id="custom-header-drawer-{{ section.id }}"
        class="custom-header__drawer custom-header__mobile-drawer"
        data-mobile-menu-drawer
        aria-hidden="true"
      >
        <div class="custom-header__drawer-panel">
          <div class="custom-header__drawer-header">
            <span class="custom-header__drawer-label">Menu</span>
            <button type="button" class="custom-header__drawer-close" data-mobile-menu-close aria-label="Close menu">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"/>
              </svg>
            </button>
          </div>

          <nav class="custom-header__menu custom-header__menu--mobile" aria-label="Mobile navigation">
            <ul class="custom-header__menu-list custom-header__menu-list--mobile">
              {% for link in nav_links %}
                <li class="custom-header__menu-item custom-header__menu-item--mobile{% if link.links != blank %} custom-header__menu-item--mobile-nested{% endif %}">
                  {% if link.links != blank %}
                    <details class="custom-header__mobile-disclosure">
                      <summary class="custom-header__mobile-summary">
                        <span>{{ link.title }}</span>
                        <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                          <path d="M4 6.5 8 10.5l4-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                        </svg>
                      </summary>
                      <ul class="custom-header__mobile-submenu" role="list">
                        {% for child_link in link.links %}
                          <li><a href="{{ child_link.url }}" class="custom-header__mobile-submenu-link">{{ child_link.title }}</a></li>
                        {% endfor %}
                      </ul>
                    </details>
                  {% else %}
                    <a href="{{ link.url }}" class="custom-header__menu-link">{{ link.title }}</a>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </nav>
        </div>
      </div>
    {% endif %}
  </div>
</header>

{% if section.settings.show_mobile_bottom_nav %}
  <nav class="custom-header__bottom-nav" aria-label="Mobile quick links">
    <a
      href="{{ shop_link }}"
      class="custom-header__bottom-nav-item{% if request_path contains '/collections' or request_path contains '/products' %} is-active{% endif %}"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M4.75 7.25h14.5v10.5H4.75zM8 7.25V6a4 4 0 0 1 8 0v1.25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
      </svg>
      <span>Shop</span>
    </a>
    <a
      href="{{ routes.cart_url }}"
      class="custom-header__bottom-nav-item{% if request_path contains '/cart' %} is-active{% endif %}"
      data-nv-cart-drawer-open
      aria-label="Cart"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M3.75 5.25h1.8l1.68 9.24a1.5 1.5 0 0 0 1.48 1.23h7.82a1.5 1.5 0 0 0 1.46-1.16l1.32-5.64a1.5 1.5 0 0 0-1.46-1.84H7.37" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
        <circle cx="10" cy="19" r="1.25" fill="currentColor"/>
        <circle cx="17" cy="19" r="1.25" fill="currentColor"/>
      </svg>
      <span>Cart</span>
      {% if cart.item_count > 0 %}
        <span class="custom-header__bottom-nav-badge" aria-hidden="true" data-nv-cart-badge>{{ cart.item_count }}</span>
      {% endif %}
    </a>
    <a
      href="{{ routes.account_login_url }}"
      class="custom-header__bottom-nav-item{% if request_path contains '/account' %} is-active{% endif %}"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 12a4.25 4.25 0 1 0 0-8.5 4.25 4.25 0 0 0 0 8.5Zm0 2c-4.26 0-7.5 2.31-7.5 5.1 0 .5.4.9.9.9h13.2c.5 0 .9-.4.9-.9C19.5 16.31 16.26 14 12 14Z" fill="currentColor"/>
      </svg>
      <span>My account</span>
    </a>
  </nav>
{% endif %}

<script>
  (() => {
    const header = document.getElementById('custom-header-{{ section.id }}');
    if (!header || !header.classList.contains('custom-header')) return;

    const toggles = header.querySelectorAll('.custom-header__submenu-toggle');
    const desktopMenuItems = header.querySelectorAll('.custom-header__menu-item--has-children');
    const menuTrigger = header.querySelector('.custom-header__menu-trigger');
    const drawer = header.querySelector('[data-mobile-menu-drawer]');
    const backdrop = header.querySelector('[data-mobile-menu-backdrop]');
    const closeButton = header.querySelector('[data-mobile-menu-close]');
    const mobileDisclosures = header.querySelectorAll('.custom-header__mobile-disclosure');
    const desktopMedia = window.matchMedia('(min-width: 981px)');
    const hoverTimers = new WeakMap();

    const setDesktopItemState = (item, isOpen) => {
      if (!item) return;
      item.classList.toggle('is-open', isOpen);
      item.querySelector('.custom-header__submenu-toggle')?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };

    const closeAll = (exceptItem) => {
      desktopMenuItems.forEach((item) => {
        if (item === exceptItem) return;
        setDesktopItemState(item, false);
      });
    };

    if (toggles.length) {
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', (event) => {
          event.preventDefault();
          const item = toggle.closest('.custom-header__menu-item--has-children');
          const isOpen = item.classList.contains('is-open');
          closeAll(item);
          setDesktopItemState(item, !isOpen);
        });
      });

      desktopMenuItems.forEach((item) => {
        item.addEventListener('mouseenter', () => {
          if (!desktopMedia.matches) return;
          const timer = hoverTimers.get(item);
          if (timer) {
            window.clearTimeout(timer);
          }
          closeAll(item);
          setDesktopItemState(item, true);
        });

        item.addEventListener('mouseleave', () => {
          if (!desktopMedia.matches) return;
          const timer = window.setTimeout(() => {
            setDesktopItemState(item, false);
          }, 110);
          hoverTimers.set(item, timer);
        });
      });

      document.addEventListener('click', (event) => {
        if (!event.target.closest('.custom-header__menu-item--has-children')) {
          closeAll();
        }
      });
    }

    if (!menuTrigger || !drawer || !backdrop) return;

    const setDrawerState = (isOpen) => {
      header.classList.toggle('is-mobile-menu-open', isOpen);
      drawer.classList.toggle('is-open', isOpen);
      backdrop.classList.toggle('is-open', isOpen);
      menuTrigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      menuTrigger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      backdrop.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      document.body.classList.toggle('custom-header-mobile-open', isOpen);

      if (!isOpen) {
        mobileDisclosures.forEach((disclosure) => {
          disclosure.removeAttribute('open');
        });
      }
    };

    const closeDrawer = () => setDrawerState(false);

    menuTrigger.addEventListener('click', () => {
      const isOpen = menuTrigger.getAttribute('aria-expanded') === 'true';
      setDrawerState(!isOpen);
    });

    closeButton?.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    mobileDisclosures.forEach((disclosure) => {
      disclosure.addEventListener('toggle', () => {
        if (!disclosure.open) return;
        mobileDisclosures.forEach((other) => {
          if (other !== disclosure) {
            other.removeAttribute('open');
          }
        });
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeAll();
        closeDrawer();
      }
    });

    const syncDesktopState = () => {
      if (desktopMedia.matches) {
        closeDrawer();
      } else {
        closeAll();
      }
    };

    if (desktopMedia.addEventListener) {
      desktopMedia.addEventListener('change', syncDesktopState);
    } else {
      desktopMedia.addListener(syncDesktopState);
    }

    setDrawerState(false);
  })();
</script>

<style>
  :root{
    --nv-header-bg: {{ section.settings.header_background_color }};
    --nv-header-link: {{ section.settings.nav_link_color }};
    --nv-header-link-hover: {{ section.settings.nav_link_hover_color }};
    --nv-header-icon: {{ section.settings.utility_link_color }};
    --nv-header-icon-hover: {{ section.settings.utility_link_hover_color }};
    --nv-header-logo-width: {{ section.settings.header_logo_width }}px;
    --nv-header-logo-mobile-width: {{ section.settings.header_logo_max_width_mobile }}px;
    --nv-header-nav-size: {{ section.settings.nav_font_size }}px;
    --nv-header-nav-weight: {{ section.settings.nav_font_weight }};
    --nv-header-nav-letter-spacing: {{ section.settings.nav_letter_spacing | times: 0.01 }}em;
    --nv-header-nav-transform: {{ section.settings.nav_text_transform }};
    --nv-header-utility-size: {{ section.settings.utility_font_size }}px;
    --nv-header-icon-size: {{ section.settings.utility_icon_size }}px;
    --nv-header-pad-top: {{ section.settings.header_padding_top }}px;
    --nv-header-pad-bottom: {{ section.settings.header_padding_bottom }}px;
    --nv-header-top-row-pad-top: {{ section.settings.header_top_row_padding_top }}px;
    --nv-header-top-row-pad-bottom: {{ section.settings.header_top_row_padding_bottom }}px;
    --nv-header-bottom-row-pad-top: {{ section.settings.header_bottom_row_padding_top }}px;
    --nv-header-bottom-row-pad-bottom: {{ section.settings.header_bottom_row_padding_bottom }}px;
    --nv-header-top-row-min-height: {{ section.settings.header_top_row_min_height }}px;
    --nv-header-bottom-row-min-height: {{ section.settings.header_bottom_row_min_height }}px;
    --nv-header-max-width: {{ section.settings.header_content_max_width }}px;
    --nv-header-gap: {{ section.settings.header_column_gap }}px;
    --nv-header-row-gap: {{ section.settings.header_row_gap }}px;
    --nv-header-utility-gap: {{ section.settings.utility_item_gap }}px;
    --nv-header-nav-item-gap: {{ section.settings.nav_item_gap }}px;
    --nv-header-border: {{ section.settings.header_border_color }};
    --nv-header-border-alpha: {% if section.settings.header_enable_bottom_border %}1{% else %}0{% endif %};
    --nv-header-shadow-alpha: {{ section.settings.header_shadow_opacity | divided_by: 100.0 }};
    --nv-header-dropdown-shadow-alpha: {{ section.settings.dropdown_shadow_opacity | divided_by: 100.0 }};
    --nv-header-sticky-top-row-bg: {{ section.settings.sticky_top_row_background_color }};
    --nv-header-sticky-top-row-border: {{ section.settings.sticky_top_row_border_color }};
    --nv-header-sticky-top-row-shadow-alpha: {{ section.settings.sticky_top_row_shadow_opacity | divided_by: 100.0 }};
    --nv-header-hover-style: {{ section.settings.nav_hover_style }};
    --nv-mobile-header-height: {{ section.settings.mobile_header_height }}px;
    --nv-mobile-header-pad-top: {{ section.settings.mobile_header_padding_top }}px;
    --nv-mobile-header-pad-bottom: {{ section.settings.mobile_header_padding_bottom }}px;
    --nv-mobile-header-pad-x: {{ section.settings.mobile_header_horizontal_padding }}px;
    --nv-mobile-header-min-height: {{ section.settings.mobile_header_min_height }}px;
    --nv-mobile-header-icon-size: {{ section.settings.mobile_utility_icon_size }}px;
    --nv-mobile-header-row-gap: {{ section.settings.mobile_header_row_gap }}px;
    --nv-mobile-header-bg: {{ section.settings.mobile_header_background_color }};
    --nv-mobile-header-border: {{ section.settings.mobile_header_border_color }};
    --nv-mobile-amazon-bg: {{ section.settings.mobile_amazon_button_background }};
    --nv-mobile-amazon-text: {{ section.settings.mobile_amazon_button_text_color }};
    --nv-mobile-bottom-nav-bg: {{ section.settings.mobile_bottom_nav_background }};
    --nv-mobile-bottom-nav-border: {{ section.settings.mobile_bottom_nav_border_color }};
    --nv-mobile-bottom-nav-text: {{ section.settings.mobile_bottom_nav_text_color }};
    --nv-mobile-bottom-nav-active: {{ section.settings.mobile_bottom_nav_active_color }};
    --nv-mobile-bottom-nav-icon-size: {{ section.settings.mobile_bottom_nav_icon_size }}px;
    --nv-mobile-bottom-nav-font-size: {{ section.settings.mobile_bottom_nav_font_size }}px;
    --nv-mobile-bottom-nav-height: {{ section.settings.mobile_bottom_nav_height }}px;
  }
</style>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "paragraph",
      "content": "Use the Custom Announcement Bar section directly above this header for the top message area."
    },
    {
      "type": "header",
      "content": "Logo and navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu"
    },
    {
      "type": "link_list",
      "id": "left_menu",
      "label": "Legacy menu fallback"
    },
    {
      "type": "image_picker",
      "id": "header_logo",
      "label": "Header logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Legacy logo fallback"
    },
    {
      "type": "range",
      "id": "header_logo_width",
      "label": "Logo width",
      "min": 70,
      "max": 200,
      "step": 5,
      "default": 90,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "header_logo_max_width_mobile",
      "label": "Mobile logo width",
      "min": 60,
      "max": 160,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "label": "Navigation font size",
      "min": 11,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "nav_font_weight",
      "label": "Navigation font weight",
      "default": "600",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "nav_letter_spacing",
      "label": "Navigation letter spacing",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "em"
    },
    {
      "type": "select",
      "id": "nav_text_transform",
      "label": "Navigation text transform",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" }
      ]
    },
    {
      "type": "color",
      "id": "nav_link_color",
      "label": "Navigation link color",
      "default": "#181A17"
    },
    {
      "type": "color",
      "id": "nav_link_hover_color",
      "label": "Navigation hover color",
      "default": "#6E8F67"
    },
    {
      "type": "select",
      "id": "nav_hover_style",
      "label": "Navigation hover style",
      "default": "underline",
      "options": [
        { "value": "underline", "label": "Underline" },
        { "value": "color", "label": "Color shift" }
      ]
    },
    {
      "type": "header",
      "content": "Utility area"
    },
    {
