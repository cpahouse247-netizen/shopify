        },
        {
          "type": "text",
          "id": "description",
          "label": "One-line description",
          "default": "Defend your body naturally"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NV Health Goals",
      "blocks": [
        {
          "type": "goal",
          "settings": {
            "icon": "🛡️",
            "title": "Immune Support",
            "description": "Defend your body naturally",
            "link": "/collections/all"
          }
        },
        {
          "type": "goal",
          "settings": {
            "icon": "💪",
            "title": "Men's Health",
            "description": "Prostate and vitality support",
            "link": "/collections/all"
          }
        },
        {
          "type": "goal",
          "settings": {
            "icon": "❤️",
            "title": "Heart & Circulation",
