<section
  id="nv-final-cta-{{ section.id }}"
  class="nv-section nv-final-cta nv-final-cta--{{ section.settings.layout_style }} nv-final-cta--{{ section.settings.text_alignment }}"
  style="
    --nv-final-cta-bg: {{ section.settings.background_color }};
    --nv-final-cta-text: {{ section.settings.text_color }};
    --nv-final-cta-border: {{ section.settings.border_color | default: '#D9DED8' }};
    --nv-final-cta-accent: {{ section.settings.accent_color | default: '#C8A96B' }};
    --nv-final-cta-shadow-opacity: {{ section.settings.shadow_opacity | default: 10 | divided_by: 100.0 }};
    --nv-final-cta-panel-padding: {{ section.settings.panel_padding | default: 56 }}px;
    --nv-final-cta-max-width: {{ section.settings.content_max_width }}px;
    --nv-final-cta-heading-size: {{ section.settings.heading_font_size }}px;
    --nv-final-cta-body-size: {{ section.settings.body_font_size }}px;
    --nv-final-cta-button-size: {{ section.settings.button_font_size }}px;
    --nv-final-cta-pad-top: {{ section.settings.section_padding_top }}px;
    --nv-final-cta-pad-bottom: {{ section.settings.section_padding_bottom }}px;
    --nv-final-cta-radius: {{ section.settings.border_radius }}px;
    --nv-final-cta-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  <div class="nv-final-cta__shell">
    <div class="nv-final-cta__panel{% if section.settings.background_image != blank %} nv-final-cta__panel--image{% endif %}">
      {% if section.settings.background_image != blank %}
        <div class="nv-final-cta__media">
          {{
            section.settings.background_image
            | image_url: width: 1800
            | image_tag:
              loading: 'lazy',
              class: 'nv-final-cta__media-image',
              alt: section.settings.heading
          }}
        </div>
      {% endif %}

      <div class="nv-final-cta__content">
        {% if section.settings.eyebrow_text != blank %}
          <p class="nv-final-cta__eyebrow nv-eyebrow" data-nv-animate="fade-up">{{ section.settings.eyebrow_text }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="nv-final-cta__heading nv-h2 nv-heading" data-nv-animate="fade-up" data-nv-delay="100">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="nv-final-cta__body rte nv-body-lg" data-nv-animate="fade-up" data-nv-delay="200">{{ section.settings.body_text }}</div>
        {% endif %}

        <div class="nv-final-cta__actions" data-nv-animate="fade-up" data-nv-delay="300">
          {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
            <a
              href="{{ section.settings.primary_button_link }}"
              target="_blank"
              rel="noopener noreferrer"
              class="nv-final-cta__button nv-final-cta__button--primary nv-final-cta__button--{{ section.settings.button_style_variant }} nv-btn nv-btn--amazon nv-btn--lg nv-btn--pulse"
            >
              {{ section.settings.primary_button_label | remove: '→' | strip }} <span class="nv-btn__amazon-arrow">→</span>
            </a>
          {% endif %}

          {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
            <a
              href="{{ section.settings.secondary_button_link }}"
              class="nv-final-cta__button nv-final-cta__button--secondary nv-btn nv-btn--outline-white nv-btn--lg"
            >
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.show_trust_note and section.settings.trust_note != blank %}
          <p class="nv-final-cta__trust-note" data-nv-animate="fade-in" data-nv-delay="400">{{ section.settings.trust_note }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #nv-final-cta-{{ section.id }}{
    padding-top:var(--nv-final-cta-pad-top, 88px);
    padding-bottom:var(--nv-final-cta-pad-bottom, 88px);
    background:transparent;
    color:var(--nv-final-cta-text, #181A17);
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__shell{
    width:min(calc(100% - 40px), 1320px);
    margin:0 auto;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__panel{
    position:relative;
    overflow:hidden;
    display:grid;
    gap:0;
    border-radius:var(--nv-final-cta-radius, 28px);
    border:1px solid color-mix(in srgb, var(--nv-final-cta-border, #D9DED8) 86%, transparent);
    background:
      radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--nv-final-cta-accent, #C8A96B) 16%, transparent) 0%, transparent 38%),
      linear-gradient(135deg, rgba(255,255,255,.82), rgba(255,255,255,.36)),
      var(--nv-final-cta-bg, #F7F4EE);
    box-shadow:0 24px 70px rgba(31,58,47,var(--nv-final-cta-shadow-opacity, .10));
    min-height:320px;
    isolation:isolate;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__panel::before{
    content:"";
    position:absolute;
    inset:18px;
    border:1px solid rgba(255,255,255,.52);
    border-radius:max(18px, calc(var(--nv-final-cta-radius, 28px) - 12px));
    pointer-events:none;
    z-index:1;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__panel--image::after{
    content:"";
    position:absolute;
    inset:0;
    background:linear-gradient(135deg, rgba(255,255,255,.88), rgba(247,244,238,.72));
    opacity:var(--nv-final-cta-overlay-opacity, .24);
    z-index:1;
    pointer-events:none;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__media{
    position:absolute;
    inset:0;
    z-index:0;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__media-image{
    width:100%;
    height:100%;
    object-fit:cover;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__content{
    position:relative;
    z-index:2;
    width:min(100%, var(--nv-final-cta-max-width, 780px));
    display:grid;
    align-content:center;
    gap:16px;
    padding:var(--nv-final-cta-panel-padding, 56px) clamp(24px, 5vw, 68px);
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--centered .nv-final-cta__content{
    margin:0 auto;
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--split .nv-final-cta__content{
    margin:0;
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--center .nv-final-cta__content{
    text-align:center;
    justify-items:center;
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--left .nv-final-cta__content{
    text-align:left;
    justify-items:start;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__eyebrow{
    margin:0;
    color:color-mix(in srgb, var(--nv-final-cta-accent, #C8A96B) 45%, #315C4A);
    font-size:11px;
    font-weight:800;
    letter-spacing:.18em;
    text-transform:uppercase;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__heading{
    margin:0;
    color:inherit;
    font-size:clamp(30px, 4vw, var(--nv-final-cta-heading-size, 42px));
    line-height:1.05;
    letter-spacing:-0.032em;
    max-width:16ch;
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--center .nv-final-cta__heading{
    max-width:18ch;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__body{
    max-width:58ch;
    color:rgba(24,26,23,.76);
    font-size:var(--nv-final-cta-body-size, 15px);
    line-height:1.7;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__body p{
    margin:0;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__actions{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    justify-content:flex-start;
    gap:12px;
    margin-top:6px;
  }
  #nv-final-cta-{{ section.id }}.nv-final-cta--center .nv-final-cta__actions{
    justify-content:center;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:46px;
    padding:0 24px;
    border-radius:999px;
    font-size:var(--nv-final-cta-button-size, 14px);
    font-weight:600;
    letter-spacing:.01em;
    box-shadow:0 12px 26px rgba(31,58,47,.10);
    transition:transform .18s ease, background-color .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button:hover,
  #nv-final-cta-{{ section.id }} .nv-final-cta__button:focus-visible{
    transform:translateY(-1px);
    box-shadow:0 15px 30px rgba(31,58,47,.14);
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--primary{
    background:#1F3A2F;
    color:#FFFFFF;
    border:1px solid #1F3A2F;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--primary:hover,
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--primary:focus-visible{
    background:#315C4A;
    border-color:#315C4A;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--primary.nv-final-cta__button--soft{
    background:#315C4A;
    border-color:#315C4A;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--secondary{
    background:rgba(255,255,255,.82);
    color:#1F3A2F;
    border:1px solid rgba(217,222,216,.95);
    box-shadow:none;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--secondary:hover,
  #nv-final-cta-{{ section.id }} .nv-final-cta__button--secondary:focus-visible{
    background:#FFFFFF;
    border-color:#D9DED8;
  }
  #nv-final-cta-{{ section.id }} .nv-final-cta__trust-note{
    margin:4px 0 0;
    color:rgba(24,26,23,.62);
    font-size:12px;
    line-height:1.6;
    letter-spacing:.02em;
  }

  @media (max-width: 749px){
    #nv-final-cta-{{ section.id }}{
      padding-top:max(56px, calc(var(--nv-final-cta-pad-top, 88px) - 24px));
      padding-bottom:max(56px, calc(var(--nv-final-cta-pad-bottom, 88px) - 24px));
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__shell{
      width:min(calc(100% - 28px), 1320px);
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__panel{
      min-height:auto;
      border-radius:max(20px, calc(var(--nv-final-cta-radius, 28px) - 6px));
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__panel::before{
      inset:10px;
      border-radius:max(16px, calc(var(--nv-final-cta-radius, 28px) - 10px));
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__content{
      width:100%;
      padding:max(32px, calc(var(--nv-final-cta-panel-padding, 56px) - 22px)) 18px;
      gap:14px;
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__heading{
      max-width:none;
      font-size:clamp(25px, 7vw, 32px);
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__body{
      max-width:none;
      font-size:min(var(--nv-final-cta-body-size, 15px), 14px);
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__actions{
      width:100%;
      flex-direction:column;
      align-items:stretch;
    }
    #nv-final-cta-{{ section.id }} .nv-final-cta__button{
      width:100%;
      min-height:44px;
    }
  }
</style>

{% schema %}
{
  "name": "NV Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Ready to explore"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the formula that fits your routine."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Browse NutraVora’s premium supplement collection or visit our official Amazon store for trusted fulfillment.</p>"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Visit Amazon Store"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "checkbox",
      "id": "show_trust_note",
      "label": "Show trust note",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_note",
      "label": "Trust note",
      "default": "Official NutraVora product listings. Prime-enabled where available."
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "default": "centered",
      "options": [
        { "value": "centered", "label": "Centered" },
        { "value": "split", "label": "Split" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "button_style_variant",
      "label": "Primary button style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "soft", "label": "Soft" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F4EE"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Panel border color",
      "default": "#D9DED8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C8A96B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#181A17"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 520,
      "max": 920,
      "step": 20,
      "default": 720,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 32,
      "max": 56,
      "step": 2,
      "default": 42,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 14,
      "max": 18,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 13,
      "max": 16,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 140,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 140,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "panel_padding",
      "label": "Panel inner padding",
      "min": 32,
      "max": 84,
      "step": 4,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Panel shadow",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Container border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 25,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "NV Final CTA"
    }
  ]
}
{% endschema %}
