<section class="section section--tight nv-home-benefit-nav">
  <div class="container">
    <div class="section-heading">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="nv-home-benefit-nav__grid">
      {% for block in section.blocks %}
        <a class="surface-card nv-home-benefit-nav__card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {% if block.settings.label != blank %}
            <h3>{{ block.settings.label }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "NV Home Benefit Nav",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by focus" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore formulas by wellness goal or ingredient story." }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Navigation card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Immune support" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Clean support formulas designed for daily confidence." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "NV Home Benefit Nav",
      "blocks": [
        { "type": "link", "settings": { "label": "Immune support" } },
        { "type": "link", "settings": { "label": "Gut wellness" } },
        { "type": "link", "settings": { "label": "Heart health" } },
        { "type": "link", "settings": { "label": "Daily essentials" } }
      ]
    }
  ]
}
{% endschema %}
