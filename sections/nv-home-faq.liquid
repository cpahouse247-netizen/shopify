{% liquid
  assign text_align = section.settings.text_alignment | default: 'center'
%}

<section
  id="nv-faq-{{ section.id }}"
  class="nv-section nv-faq nv-faq--{{ text_align }}"
  style="
    --nv-faq-max-width: {{ section.settings.max_width }}px;
    --nv-faq-padding-top: {{ section.settings.padding_top }}px;
    --nv-faq-padding-bottom: {{ section.settings.padding_bottom }}px;
    --nv-faq-bg: {{ section.settings.background_color }};
    --nv-faq-text: {{ section.settings.text_color }};
    --nv-faq-accent: {{ section.settings.accent_color | default: '#315C4A' }};
    --nv-faq-surface: {{ section.settings.surface_color | default: '#FFFFFF' }};
    --nv-faq-border: {{ section.settings.border_color | default: '#D9DED8' }};
    --nv-faq-radius: {{ section.settings.border_radius | default: 28 }}px;
    --nv-faq-shadow-opacity: {{ section.settings.shadow_opacity | default: 8 | divided_by: 100.0 }};
    --nv-faq-label-size: {{ section.settings.label_font_size | default: 11 }}px;
    --nv-faq-heading-size: {{ section.settings.heading_font_size | default: 42 }}px;
    --nv-faq-subheading-size: {{ section.settings.subheading_font_size | default: 15 }}px;
    --nv-faq-question-size: {{ section.settings.question_font_size }}px;
    --nv-faq-answer-size: {{ section.settings.answer_font_size }}px;
  "
>
  <div class="nv-faq__container">
    {% if section.settings.label != blank or section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="nv-faq__header">
        {% if section.settings.label != blank %}
          <p class="nv-faq__label">{{ section.settings.label }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="nv-faq__heading nv-section-heading" data-nv-animate="fade-up">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="nv-faq__subheading rte">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="nv-faq__list" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.question != blank %}
          {% assign answer_id = 'nv-faq-answer-' | append: section.id | append: '-' | append: block.id %}
          {%- liquid
            assign animation_delay = forloop.index0 | times: 100 | plus: 100
            if animation_delay > 800
              assign animation_delay = 800
            endif
          -%}
          <div class="nv-faq__item" data-nv-animate="fade-up" data-nv-delay="{{ animation_delay }}" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="nv-faq__question"
              aria-expanded="false"
              aria-controls="{{ answer_id }}"
            >
              <span class="nv-faq__question-text">{{ block.settings.question }}</span>
              <span class="nv-faq__icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" focusable="false">
                  <path d="M5.5 7.5 10 12l4.5-4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                </svg>
              </span>
            </button>

            <div
              id="{{ answer_id }}"
              class="nv-faq__answer"
              hidden
            >
              <div class="nv-faq__answer-inner rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <div class="nv-faq__empty">
          <p>Add FAQ blocks in Theme Editor to build this section.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #nv-faq-{{ section.id }}{
    background:
      radial-gradient(circle at 50% 0%, rgba(255,255,255,.88), rgba(255,255,255,0) 36%),
      radial-gradient(circle at 14% 8%, rgba(200,169,107,.10), transparent 34%),
      linear-gradient(180deg, rgba(255,255,255,.82), rgba(247,244,238,.66)),
      var(--nv-faq-bg, #FFFFFF);
    color:var(--nv-faq-text, #181A17);
    padding-top:clamp(38px, 4.2vw, var(--nv-faq-padding-top, 88px));
    padding-bottom:clamp(48px, 4.8vw, var(--nv-faq-padding-bottom, 88px));
    border-top:1px solid rgba(49,92,74,.08);
    border-bottom:1px solid rgba(49,92,74,.08);
  }
  #nv-faq-{{ section.id }} .nv-faq__container{
    width:min(calc(100% - 40px), max(var(--nv-faq-max-width, 980px), 1120px));
    margin:0 auto;
  }
  #nv-faq-{{ section.id }} .nv-faq__header{
    margin-bottom:clamp(24px, 2.7vw, 34px);
  }
  #nv-faq-{{ section.id }}.nv-faq--center .nv-faq__header{
    text-align:center;
  }
  #nv-faq-{{ section.id }}.nv-faq--left .nv-faq__header{
    text-align:left;
  }
  #nv-faq-{{ section.id }} .nv-faq__label{
    margin:0 0 10px;
    color:color-mix(in srgb, var(--nv-faq-accent, #315C4A) 72%, #C8A96B);
    font-size:var(--nv-faq-label-size, 11px);
    font-weight:800;
    letter-spacing:.18em;
    text-transform:uppercase;
  }
  #nv-faq-{{ section.id }} .nv-faq__heading{
    margin:0;
    max-width:min(100%, 22ch);
    color:inherit;
    font-size:clamp(28px, 4vw, var(--nv-faq-heading-size, 42px));
    line-height:1.06;
    letter-spacing:-0.03em;
  }
  #nv-faq-{{ section.id }}.nv-faq--center .nv-faq__heading{
    margin-left:auto;
    margin-right:auto;
  }
  #nv-faq-{{ section.id }} .nv-faq__subheading{
    margin-top:12px;
    max-width:54ch;
    color:rgba(24,26,23,.72);
    font-size:var(--nv-faq-subheading-size, 15px);
    line-height:1.7;
  }
  #nv-faq-{{ section.id }}.nv-faq--center .nv-faq__subheading{
    margin-left:auto;
    margin-right:auto;
  }
  #nv-faq-{{ section.id }} .nv-faq__list{
    padding:8px;
    border:1px solid color-mix(in srgb, var(--nv-faq-border, #D9DED8) 84%, transparent);
    border-radius:var(--nv-faq-radius, 28px);
    background:
      linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,255,255,.46)),
      var(--nv-faq-surface, #FFFFFF);
    box-shadow:0 20px 52px rgba(31,58,47,var(--nv-faq-shadow-opacity, .08));
  }
  #nv-faq-{{ section.id }} .nv-faq__item{
    border-bottom:1px solid rgba(217,222,216,.68);
  }
  #nv-faq-{{ section.id }} .nv-faq__item:last-child{
    border-bottom:0;
  }
  #nv-faq-{{ section.id }} .nv-faq__question{
    width:100%;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;
    padding:19px 18px;
    border-radius:max(18px, calc(var(--nv-faq-radius, 28px) - 12px));
    border:0;
    background:transparent;
    color:inherit;
    text-align:left;
    cursor:pointer;
  }
  #nv-faq-{{ section.id }} .nv-faq__question:hover,
  #nv-faq-{{ section.id }} .nv-faq__question:focus-visible,
  #nv-faq-{{ section.id }} .nv-faq__item.is-open .nv-faq__question{
    background:rgba(49,92,74,.045);
    outline:none;
  }
  #nv-faq-{{ section.id }} .nv-faq__question-text{
    font-size:var(--nv-faq-question-size, 16px);
    font-weight:600;
    line-height:1.4;
    letter-spacing:-0.01em;
  }
  #nv-faq-{{ section.id }} .nv-faq__icon{
    flex:0 0 auto;
    width:24px;
    height:24px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    color:var(--nv-faq-accent, #315C4A);
    transition:transform .22s ease, color .22s ease;
  }
  #nv-faq-{{ section.id }} .nv-faq__icon svg{
    width:18px;
    height:18px;
  }
  #nv-faq-{{ section.id }} .nv-faq__item.is-open .nv-faq__icon{
    transform:rotate(180deg);
    color:#1F3A2F;
  }
  #nv-faq-{{ section.id }} .nv-faq__answer{
    height:0;
    overflow:hidden;
    opacity:0;
    transition:height .26s ease, opacity .2s ease;
  }
  #nv-faq-{{ section.id }} .nv-faq__answer-inner{
    padding:0 0 20px;
    padding-left:18px;
    padding-right:58px;
    color:rgba(24,26,23,.72);
    font-size:var(--nv-faq-answer-size, 15px);
    line-height:1.7;
  }
  #nv-faq-{{ section.id }} .nv-faq__answer-inner p:first-child{
    margin-top:0;
  }
  #nv-faq-{{ section.id }} .nv-faq__answer-inner p:last-child{
    margin-bottom:0;
  }
  #nv-faq-{{ section.id }} .nv-faq__empty{
    padding:22px 0 0;
    color:rgba(24,26,23,.62);
    font-size:14px;
  }

  @media (max-width: 749px){
    #nv-faq-{{ section.id }}{
      padding-top:max(42px, calc(var(--nv-faq-padding-top, 88px) - 30px));
      padding-bottom:max(48px, calc(var(--nv-faq-padding-bottom, 88px) - 30px));
    }
    #nv-faq-{{ section.id }} .nv-faq__container{
      width:min(calc(100% - 28px), var(--nv-faq-max-width, 980px));
    }
    #nv-faq-{{ section.id }} .nv-faq__header{
      margin-bottom:24px;
    }
    #nv-faq-{{ section.id }} .nv-faq__heading{
      max-width:100%;
      font-size:min(var(--nv-faq-heading-size, 42px), clamp(24px, 7vw, 32px));
    }
    #nv-faq-{{ section.id }} .nv-faq__subheading{
      font-size:min(var(--nv-faq-subheading-size, 15px), 14px);
      line-height:1.65;
    }
    #nv-faq-{{ section.id }} .nv-faq__list{
      padding:6px;
      border-radius:max(20px, calc(var(--nv-faq-radius, 28px) - 6px));
    }
    #nv-faq-{{ section.id }} .nv-faq__question{
      gap:14px;
      padding:16px 12px;
    }
    #nv-faq-{{ section.id }} .nv-faq__question-text{
      font-size:min(var(--nv-faq-question-size, 16px), 15px);
    }
    #nv-faq-{{ section.id }} .nv-faq__answer-inner{
      padding:0 12px 18px;
      font-size:min(var(--nv-faq-answer-size, 15px), 14px);
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById('nv-faq-{{ section.id }}');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.nv-faq__item'));
    if (!items.length) return;

    const closeItem = (item) => {
      const button = item.querySelector('.nv-faq__question');
      const answer = item.querySelector('.nv-faq__answer');
      if (!button || !answer) return;

      item.classList.remove('is-open');
      button.setAttribute('aria-expanded', 'false');
      answer.style.height = `${answer.scrollHeight}px`;

      requestAnimationFrame(() => {
        answer.style.height = '0px';
        answer.style.opacity = '0';
      });

      window.setTimeout(() => {
        if (!item.classList.contains('is-open')) {
          answer.hidden = true;
        }
      }, 260);
    };

    const openItem = (item) => {
      const button = item.querySelector('.nv-faq__question');
      const answer = item.querySelector('.nv-faq__answer');
      if (!button || !answer) return;

      items.forEach((otherItem) => {
        if (otherItem !== item) {
          closeItem(otherItem);
        }
      });

      item.classList.add('is-open');
      button.setAttribute('aria-expanded', 'true');
      answer.hidden = false;
      answer.style.height = '0px';
      answer.style.opacity = '0';

      requestAnimationFrame(() => {
        answer.style.height = `${answer.scrollHeight}px`;
        answer.style.opacity = '1';
      });

      window.setTimeout(() => {
        if (item.classList.contains('is-open')) {
          answer.style.height = 'auto';
        }
      }, 260);
    };

    items.forEach((item) => {
      const button = item.querySelector('.nv-faq__question');
      if (!button) return;

      button.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        if (isOpen) {
          closeItem(item);
        } else {
          openItem(item);
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "NV Home FAQ",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Helpful answers about ordering, delivery, and how to shop with confidence.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 900,
      "max": 1100,
      "step": 20,
      "default": 980,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 40,
      "max": 140,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 40,
      "max": 140,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#181A17"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#315C4A"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "FAQ surface color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "FAQ border color",
      "default": "#D9DED8"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "FAQ surface radius",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "FAQ surface shadow",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 8,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Label font size",
      "min": 10,
      "max": 14,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 28,
      "max": 54,
      "step": 2,
      "default": 42,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading font size",
      "min": 13,
      "max": 20,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "question_font_size",
      "label": "Question font size",
      "min": 15,
      "max": 17,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "label": "Answer font size",
      "min": 14,
      "max": 16,
      "step": 1,
      "default": 15,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How quickly does my order ship?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Orders are typically processed quickly, and delivery timing depends on the shipping method shown at checkout.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NV Home FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
