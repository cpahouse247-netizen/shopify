{% comment %}
  NutraVora Buy with Prime mount point.

  The Buy with Prime app or custom integration can target the data attributes
  on this container and replace the placeholder button without shifting layout.

  Inputs:
  - product: Product object
  - template_override: optional mode override
  - class: optional wrapper class
  - placeholder_label: optional visible placeholder text
  - force_render: optional boolean
  - placement: optional placement label for app targeting
{% endcomment %}
{%- liquid
  assign resolved_template_override = template_override | strip
  assign wrapper_class = class | default: 'nv-bwp-slot'
  assign placement = placement | default: 'cta'
-%}

{%- capture resolved_mode -%}{% render 'nv-conversion-context', product: product, field: 'mode', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign resolved_mode = resolved_mode | strip -%}
{%- capture primary_kind -%}{% render 'nv-conversion-context', product: product, field: 'primary_kind', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign primary_kind = primary_kind | strip -%}
{%- capture buy_with_prime_button_id -%}{% render 'nv-conversion-context', product: product, field: 'buy_with_prime_button_id', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign buy_with_prime_button_id = buy_with_prime_button_id | strip -%}
{%- capture selected_variant_id -%}{% render 'nv-conversion-context', product: product, field: 'selected_variant_id', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign selected_variant_id = selected_variant_id | strip -%}
{%- capture resolved_placeholder_label -%}{% render 'nv-conversion-context', product: product, field: 'buy_with_prime_label', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign resolved_placeholder_label = resolved_placeholder_label | strip -%}
{%- capture resolved_loading_label -%}{% render 'nv-conversion-context', product: product, field: 'buy_with_prime_loading_label', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign resolved_loading_label = resolved_loading_label | strip -%}
{%- capture show_buy_with_prime_zone -%}{% render 'nv-conversion-context', product: product, field: 'show_buy_with_prime_zone', template_override: resolved_template_override %}{%- endcapture -%}
{%- assign show_buy_with_prime_zone = show_buy_with_prime_zone | strip -%}
{%- assign placeholder_label = placeholder_label | default: resolved_placeholder_label -%}

{%- assign should_render = false -%}
{%- if resolved_mode == 'buy_with_prime' or primary_kind == 'buy_with_prime' or show_buy_with_prime_zone == 'true' or force_render -%}
  {%- assign should_render = true -%}
{%- endif -%}

{%- if should_render -%}
  <div
    class="{{ wrapper_class }}"
    data-nv-buy-with-prime-slot
    data-nv-buy-with-prime-state="loading"
    data-nv-buy-with-prime-placement="{{ placement }}"
    data-product-id="{% if product %}{{ product.id }}{% endif %}"
    data-variant-id="{{ selected_variant_id }}"
    data-buy-with-prime-button-id="{{ buy_with_prime_button_id }}"
  >
    {% comment %}
      Buy with Prime app / widget markup should mount inside this container.
      Do not hardcode merchant-specific IDs here. Apps or merchant-console
      scripts should target the data attributes above.
    {% endcomment %}
    <div class="nv-bwp-slot__placeholder" aria-hidden="true">
      <span class="nv-bwp-slot__placeholder-label">{{ placeholder_label }}</span>
    </div>
    <div class="nv-bwp-slot__loading" aria-hidden="true">
      <span class="nv-bwp-slot__loading-dot"></span>
      <span class="nv-bwp-slot__loading-label">{{ resolved_loading_label }}</span>
    </div>
    <div class="nv-bwp-slot__mount"></div>
  </div>
{%- endif -%}
