{% case icon %}
  {% when 'star' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3.5l2.7 5.47 6.03.88-4.36 4.25 1.03 6-5.4-2.84-5.4 2.84 1.03-6-4.36-4.25 6.03-.88L12 3.5z"/>
    </svg>
  {% when 'leaf' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M19 3c-6 1-12.5 4.5-14 12 3.5 1.5 11-.5 14-12z"/>
      <path d="M5 16c3-3 6-5 10-7"/>
    </svg>
  {% when 'shield' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/>
      <path d="M9.5 12.2l1.8 1.8 3.5-3.8"/>
    </svg>
  {% when 'drop' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3.5c2.7 3.3 5 6 5 9a5 5 0 1 1-10 0c0-3 2.3-5.7 5-9z"/>
    </svg>
  {% when 'capsule' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8.5 6.5a4 4 0 0 1 5.66 0l3.34 3.34a4 4 0 1 1-5.66 5.66L8.5 12.16a4 4 0 0 1 0-5.66z"/>
      <path d="M9.5 13.5l5-5"/>
    </svg>
  {% when 'check' %}
    <svg class="nv-wso__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <path d="M8.5 12.2l2.2 2.2 4.8-5"/>
    </svg>
{% endcase %}