{% comment %}Snippet: Rating Stars{% endcomment %}
{%- liquid
  assign max = 5
  assign rating_value = rating | default: 0 | plus: 0
  assign full = rating_value | floor
  assign remainder = rating_value | minus: full
  assign has_half = 0
  if remainder >= 0.5
    assign has_half = 1
  endif
  assign empty = max | minus: full | minus: has_half
-%}
{%- if rating_value > 0 -%}
  <div class="rating-stars" aria-label="{{ rating_value }} out of 5">
    {%- for i in (1..full) -%}
      <span class="rating-stars__star" aria-hidden="true">★</span>
    {%- endfor -%}
    {%- if has_half == 1 -%}
      <span class="rating-stars__star rating-stars__star--half" aria-hidden="true">★</span>
    {%- endif -%}
    {%- if empty > 0 -%}
      {%- for i in (1..empty) -%}
        <span class="rating-stars__star rating-stars__star--empty" aria-hidden="true">★</span>
      {%- endfor -%}
    {%- endif -%}
  </div>
{%- endif -%}
