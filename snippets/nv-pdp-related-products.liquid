{%- liquid
  assign related_count = 0
  if recommendations.products_count > 0
    assign related_count = recommendations.products_count
  endif

  assign fallback_collection = product.collections.first
  assign has_fallback_products = false
  if fallback_collection != blank
    for fallback_product in fallback_collection.products
      if fallback_product.id != product.id
        assign has_fallback_products = true
        break
      endif
    endfor
  endif
-%}

{%- if related_count > 0 or has_fallback_products -%}
  <section class="nv-related-products" aria-labelledby="nvRelatedProductsHeading-{{ product.id }}">
    <div class="nv-related-products__header">
      <h2 id="nvRelatedProductsHeading-{{ product.id }}" class="nv-related-products__title">You May Also Like</h2>
      <div class="nv-related-products__rule">
        <span class="nv-related-products__accent"></span>
      </div>
    </div>

    <div class="nv-related-products__grid">
      {%- assign rendered_related = 0 -%}
      {%- if related_count > 0 -%}
        {%- for related_product in recommendations.products limit: 4 -%}
          {%- assign related_variant = related_product.selected_or_first_available_variant -%}
          {%- assign related_prime = related_product.metafields.custom.buy_with_prime_enabled.value | default: related_product.metafields.custom.buy_with_prime_enabled -%}
          <article class="nv-related-products__card">
            <a class="nv-related-products__media-link" href="{{ related_product.url }}">
              <div class="nv-related-products__media">
                {%- if related_product.available == false -%}
                  <span class="nv-related-products__badge nv-related-products__badge--sold-out">Sold out</span>
                {%- elsif related_variant.compare_at_price > related_variant.price -%}
                  <span class="nv-related-products__badge nv-related-products__badge--sale">Sale</span>
                {%- endif -%}
                {%- if related_product.featured_media.preview_image -%}
                  {{ related_product.featured_media.preview_image | image_url: width: 520 | image_tag: loading: 'lazy', alt: related_product.title }}
                {%- endif -%}
              </div>
            </a>
            <div class="nv-related-products__copy">
              <h3 class="nv-related-products__card-title">
                <a href="{{ related_product.url }}">{{ related_product.title }}</a>
              </h3>
              <div class="nv-related-products__price-row">
                <span class="nv-related-products__price">{{ related_variant.price | money }}</span>
                {%- if related_variant.compare_at_price > related_variant.price -%}
                  <span class="nv-related-products__compare">{{ related_variant.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              <div class="nv-related-products__rating" aria-label="Product reviews">
                <div class="areviews_product_item areviews_stars{{ related_product.id }}" data-product-id="{{ related_product.id }}"></div>
              </div>
              {%- if related_prime -%}
                <p class="nv-related-products__prime"><span class="nv-related-products__prime-dot" aria-hidden="true"></span>Prime delivery eligible</p>
              {%- endif -%}
              {%- if related_variant != blank -%}
                {% form 'product', related_product, class: 'nv-related-products__form' %}
                  <input type="hidden" name="id" value="{{ related_variant.id }}">
                  <button type="submit" class="btn nv-related-products__cta" {% unless related_product.available %}disabled aria-disabled="true"{% endunless %}>
                    <span class="nv-related-products__cta-icon" aria-hidden="true">
                      <svg viewBox="0 0 20 20" focusable="false">
                        <path d="M6.2 15.6a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2Zm7.5 0a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2ZM3.1 3.1h1.7l1.5 8.2a2 2 0 0 0 2 1.7h5.8a2 2 0 0 0 1.9-1.4l1-4.1H6.1" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <span class="nv-related-products__cta-label">{% if related_product.available %}Add to cart{% else %}Unavailable{% endif %}</span>
                  </button>
                {% endform %}
              {%- endif -%}
            </div>
          </article>
          {%- assign rendered_related = rendered_related | plus: 1 -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if rendered_related == 0 and has_fallback_products -%}
        {%- assign fallback_rendered = 0 -%}
        {%- for related_product in fallback_collection.products -%}
          {%- if related_product.id != product.id and fallback_rendered < 4 -%}
            {%- assign related_variant = related_product.selected_or_first_available_variant -%}
            {%- assign related_prime = related_product.metafields.custom.buy_with_prime_enabled.value | default: related_product.metafields.custom.buy_with_prime_enabled -%}
            <article class="nv-related-products__card">
              <a class="nv-related-products__media-link" href="{{ related_product.url }}">
                <div class="nv-related-products__media">
                  {%- if related_product.available == false -%}
                    <span class="nv-related-products__badge nv-related-products__badge--sold-out">Sold out</span>
                  {%- elsif related_variant.compare_at_price > related_variant.price -%}
                    <span class="nv-related-products__badge nv-related-products__badge--sale">Sale</span>
                  {%- endif -%}
                  {%- if related_product.featured_media.preview_image -%}
                    {{ related_product.featured_media.preview_image | image_url: width: 520 | image_tag: loading: 'lazy', alt: related_product.title }}
                  {%- endif -%}
                </div>
              </a>
              <div class="nv-related-products__copy">
                <h3 class="nv-related-products__card-title">
                  <a href="{{ related_product.url }}">{{ related_product.title }}</a>
                </h3>
                <div class="nv-related-products__price-row">
                  <span class="nv-related-products__price">{{ related_variant.price | money }}</span>
                  {%- if related_variant.compare_at_price > related_variant.price -%}
                    <span class="nv-related-products__compare">{{ related_variant.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <div class="nv-related-products__rating" aria-label="Product reviews">
                  <div class="areviews_product_item areviews_stars{{ related_product.id }}" data-product-id="{{ related_product.id }}"></div>
                </div>
                {%- if related_prime -%}
                  <p class="nv-related-products__prime"><span class="nv-related-products__prime-dot" aria-hidden="true"></span>Prime delivery eligible</p>
                {%- endif -%}
                {%- if related_variant != blank -%}
                  {% form 'product', related_product, class: 'nv-related-products__form' %}
                    <input type="hidden" name="id" value="{{ related_variant.id }}">
                    <button type="submit" class="btn nv-related-products__cta" {% unless related_product.available %}disabled aria-disabled="true"{% endunless %}>
                      <span class="nv-related-products__cta-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20" focusable="false">
                          <path d="M6.2 15.6a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2Zm7.5 0a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2ZM3.1 3.1h1.7l1.5 8.2a2 2 0 0 0 2 1.7h5.8a2 2 0 0 0 1.9-1.4l1-4.1H6.1" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span class="nv-related-products__cta-label">{% if related_product.available %}Add to cart{% else %}Unavailable{% endif %}</span>
                    </button>
                  {% endform %}
                {%- endif -%}
              </div>
            </article>
            {%- assign fallback_rendered = fallback_rendered | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="nv-related-products__mobile-progress" aria-hidden="true">
      <span class="nv-related-products__mobile-progress-bar"></span>
    </div>
  </section>
  <script>
    (function() {
      var sections = document.querySelectorAll('.nv-related-products');
      if (!sections.length) return;

      sections.forEach(function(section) {
        var track = section.querySelector('.nv-related-products__grid');
        var bar = section.querySelector('.nv-related-products__mobile-progress-bar');
        if (!track || !bar) return;

        var update = function() {
          var max = track.scrollWidth - track.clientWidth;
          var progress = max > 0 ? track.scrollLeft / max : 0;
          var width = 22 + (78 * Math.max(0, Math.min(1, progress)));
          bar.style.transform = 'scaleX(' + (width / 100) + ')';
        };

        track.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        update();
      });
    })();
  </script>
{%- endif -%}
